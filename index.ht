    <!-- EMAIL PACKAGE -->
    <div id="gatePkgEmail" onclick="gateSelectPkg('email',this)" style="background:#fff;border:2px solid #eee;border-radius:18px;padding:18px 20px;cursor:pointer;margin-bottom:12px;position:relative;overflow:hidden;transition:border 0.2s,box-shadow 0.2s;">
