<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
<title>BeelzeAds</title>
<meta name="theme-color" content="#FFFFFF">
<link rel="icon" href="https://media.base44.com/images/public/69aeee89baab381c29ae8d31/bb2a57956_Screenshot_20260406_015157_Gallery.jpg" type="image/png">
<link rel="apple-mobile-web-app-capable" content="yes">
<link rel="apple-mobile-web-app-status-bar-style" content="black-translucent">
<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

:root {
  --bg: #f2f2f7;
  --surface: #ffffff;
  --surface2: #f2f2f7;
  --border: rgba(0,0,0,0.08);
  --text: #000000;
  --text2: #6e6e73;
  --text3: #aeaeb2;
  --accent: #6366f1;
  --accent2: #8b5cf6;
  --green: #30d158;
  --red: #ff3b30;
  --orange: #ff9f0a;
  --blue: #0a84ff;
  --radius: 16px;
  --radius-sm: 12px;
  --shadow: 0 2px 20px rgba(0,0,0,0.06);
  --shadow-md: 0 8px 40px rgba(0,0,0,0.12);
}

* { box-sizing:border-box; margin:0; padding:0; -webkit-tap-highlight-color:transparent; }

body {
  font-family: 'Inter', -apple-system, sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
  overscroll-behavior: none;
}

/* ─── SPLASH ─── */
#splash {
  position: fixed; inset: 0; z-index: 9999;
  background: #000;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 20px;
}
.splash-logo {
  width: 88px; height: 88px; border-radius: 26px;
  background: linear-gradient(145deg, #6366f1, #8b5cf6);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 0 60px rgba(99,102,241,0.6);
  animation: pulseGlow 2s ease-in-out infinite;
}
@keyframes pulseGlow {
  0%,100% { box-shadow: 0 0 40px rgba(99,102,241,0.4); }
  50% { box-shadow: 0 0 80px rgba(99,102,241,0.8); }
}
.splash-logo svg { width:44px; height:44px; color:#fff; }
.splash-title { font-size:2rem; font-weight:900; color:#fff; letter-spacing:-1px; }
.splash-sub { font-size:0.82rem; color:#666; font-weight:500; letter-spacing:0.5px; text-transform:uppercase; }
.splash-bar { width:180px; height:3px; background:#1c1c1e; border-radius:99px; overflow:hidden; margin-top:8px; }
.splash-progress { height:100%; background:linear-gradient(90deg,#6366f1,#8b5cf6); border-radius:99px; animation:loadBar 2.2s ease forwards; }
@keyframes loadBar { from{width:0%} to{width:100%} }

/* ─── LOCK ─── */
#lockScreen {
  position: fixed; inset: 0; z-index: 9998;
  background: #000;
  display: none; flex-direction: column;
  align-items: center; justify-content: center; gap: 28px;
  padding: 40px 24px;
}
.lock-avatar {
  width:80px; height:80px; border-radius:24px;
  overflow:hidden; border:2px solid #222;
  box-shadow:0 0 40px rgba(99,102,241,0.3);
}
.lock-avatar img { width:100%; height:100%; object-fit:cover; }
.lock-name { text-align:center; }
.lock-name h2 { font-size:1.5rem; font-weight:800; color:#fff; letter-spacing:-0.5px; }
.lock-name p { font-size:0.78rem; color:#555; font-weight:500; margin-top:3px; }
.lock-form { width:100%; max-width:340px; display:flex; flex-direction:column; gap:12px; }
.lock-input-wrap { position:relative; }
.lock-input-wrap input {
  width:100%; background:#111; border:1.5px solid #222; color:#fff;
  border-radius:14px; padding:14px 48px 14px 16px;
  font-size:1rem; outline:none; font-family:'Inter',sans-serif;
  transition:border 0.2s;
}
.lock-input-wrap input:focus { border-color:#6366f1; }
.lock-input-wrap input::placeholder { color:#444; }
.lock-eye { position:absolute; right:14px; top:50%; transform:translateY(-50%); cursor:pointer; color:#444; display:flex; }
.lock-error { color:#ff453a; font-size:0.78rem; text-align:center; background:#2c1212; border:1px solid #5c1f1f; border-radius:10px; padding:8px; display:none; }
.lock-btn {
  background:linear-gradient(135deg,#6366f1,#8b5cf6);
  color:#fff; border:none; border-radius:14px; padding:14px;
  font-size:0.95rem; font-weight:700; cursor:pointer;
  display:flex; align-items:center; justify-content:center; gap:8px;
  box-shadow:0 4px 20px rgba(99,102,241,0.4);
  font-family:'Inter',sans-serif;
  transition:transform 0.1s,opacity 0.15s;
}
.lock-btn:active { transform:scale(0.98); opacity:0.9; }

/* ─── APP SHELL ─── */
#app { flex-direction:column; min-height:100vh; padding-bottom:90px; }

/* ─── TOP BAR ─── */
.topbar {
  position:sticky; top:0; z-index:100;
  background:rgba(242,242,247,0.85);
  backdrop-filter:blur(20px);
  -webkit-backdrop-filter:blur(20px);
  padding:16px 20px 12px;
  display:flex; align-items:center; justify-content:space-between;
}
.topbar-left h1 { font-size:1.6rem; font-weight:800; color:var(--text); letter-spacing:-0.5px; }
.topbar-left p { font-size:0.75rem; color:var(--text2); font-weight:500; margin-top:1px; }
.topbar-right { display:flex; align-items:center; gap:10px; }
.topbar-avatar { width:34px; height:34px; border-radius:50%; overflow:hidden; border:2px solid #e5e7eb; }
.topbar-avatar img { width:100%; height:100%; object-fit:cover; }
.status-dot { width:8px; height:8px; border-radius:50%; background:var(--green); box-shadow:0 0 8px var(--green); }

/* ─── BOTTOM NAV ─── */
.bottom-nav {
  position:fixed; bottom:0; left:0; right:0; z-index:200;
  background:rgba(255,255,255,0.9);
  backdrop-filter:blur(30px);
  -webkit-backdrop-filter:blur(30px);
  border-top:1px solid var(--border);
  display:flex; align-items:center;
  padding:10px 0 max(10px, env(safe-area-inset-bottom));
}
.nav-item {
  flex:1; display:flex; flex-direction:column; align-items:center; gap:4px;
  cursor:pointer; padding:6px 4px;
  transition:all 0.2s;
}
.nav-item svg { width:22px; height:22px; color:var(--text3); transition:all 0.2s; }
.nav-item span { font-size:0.62rem; font-weight:600; color:var(--text3); transition:all 0.2s; letter-spacing:0.2px; }
.nav-item.active svg { color:var(--accent); }
.nav-item.active span { color:var(--accent); }
.nav-item-dot { width:5px; height:5px; background:var(--accent); border-radius:50%; position:absolute; top:-3px; }

/* ─── PAGES ─── */
.page { display:none; padding:0 16px; animation:fadeUp 0.3s ease; }
.page.active { display:block; }
@keyframes fadeUp { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }

/* ─── CARDS ─── */
.card {
  background:var(--surface);
  border-radius:var(--radius);
  padding:18px;
  margin-bottom:12px;
  box-shadow:var(--shadow);
}
.card-header {
  font-size:0.7rem; font-weight:700; color:var(--text2);
  text-transform:uppercase; letter-spacing:0.8px;
  display:flex; align-items:center; gap:6px; margin-bottom:14px;
}
.card-header svg { width:13px; height:13px; color:var(--accent); }

/* ─── STAT CARDS ─── */
.stats-row { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:12px; }
.stat-card {
  background:var(--surface); border-radius:var(--radius-sm);
  padding:16px; box-shadow:var(--shadow);
}
.stat-card .stat-label { font-size:0.7rem; color:var(--text2); font-weight:600; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:8px; }
.stat-card .stat-value { font-size:1.6rem; font-weight:800; color:var(--text); letter-spacing:-0.5px; }
.stat-card .stat-sub { font-size:0.72rem; color:var(--text3); font-weight:500; margin-top:3px; }
.stat-card .stat-icon { width:36px; height:36px; border-radius:10px; display:flex; align-items:center; justify-content:center; margin-bottom:10px; }
.stat-icon.purple { background:#ede9fe; }
.stat-icon.green { background:#dcfce7; }
.stat-icon.blue { background:#dbeafe; }
.stat-icon.orange { background:#fff7ed; }
.stat-icon svg { width:18px; height:18px; }
.stat-icon.purple svg { color:#6366f1; }
.stat-icon.green svg { color:#16a34a; }
.stat-icon.blue svg { color:#2563eb; }
.stat-icon.orange svg { color:#ea580c; }

/* ─── INPUTS ─── */
label { display:block; font-size:0.7rem; font-weight:700; color:var(--text2); margin-bottom:5px; text-transform:uppercase; letter-spacing:0.5px; }
input, select, textarea {
  width:100%; background:var(--bg);
  border:1.5px solid transparent;
  border-radius:var(--radius-sm); padding:12px 14px;
  font-size:0.9rem; font-family:'Inter',sans-serif;
  color:var(--text); outline:none;
  transition:border 0.15s, box-shadow 0.15s;
}
input:focus, select:focus, textarea:focus {
  border-color:var(--accent);
  box-shadow:0 0 0 3px rgba(99,102,241,0.12);
  background:#fff;
}
input::placeholder, textarea::placeholder { color:var(--text3); }
textarea { resize:vertical; min-height:110px; line-height:1.7; }
.field { margin-bottom:12px; }
.grid2 { display:grid; grid-template-columns:1fr 1fr; gap:10px; }

/* ─── COMPOSE AREA (iPhone mail style) ─── */
.compose-field {
  display:flex; align-items:flex-start; gap:12px;
  padding:13px 0; border-bottom:1px solid var(--border);
}
.compose-field:last-child { border-bottom:none; }
.compose-field label {
  font-size:0.88rem; font-weight:500; color:var(--text2);
  text-transform:none; letter-spacing:0; margin:0;
  min-width:56px; padding-top:1px;
}
.compose-field input, .compose-field textarea {
  flex:1; background:transparent; border:none; padding:0;
  font-size:0.9rem; color:var(--text); font-weight:400;
  box-shadow:none; border-radius:0;
}
.compose-field input:focus, .compose-field textarea:focus {
  background:transparent; border:none; box-shadow:none;
}
.compose-body { padding-top:14px; }
.compose-body textarea {
  width:100%; background:transparent; border:none;
  font-size:0.9rem; line-height:1.8; color:var(--text);
  min-height:200px; resize:none; padding:0;
}
.compose-body textarea:focus { box-shadow:none; background:transparent; border:none; }

/* ─── PILL TOGGLE ─── */
.pill-toggle { display:flex; background:var(--bg); border-radius:12px; padding:3px; margin-bottom:12px; }
.pill-btn {
  flex:1; padding:9px; border:none; border-radius:10px; background:transparent;
  cursor:pointer; font-size:0.83rem; font-weight:600; color:var(--text2);
  transition:all 0.2s; font-family:'Inter',sans-serif;
  display:flex; align-items:center; justify-content:center; gap:5px;
}
.pill-btn svg { width:14px; height:14px; }
.pill-btn.active { background:#fff; color:var(--accent); box-shadow:0 2px 8px rgba(0,0,0,0.1); }

/* ─── BUTTONS ─── */
.btn-primary {
  width:100%; padding:15px; background:var(--text);
  color:#fff; border:none; border-radius:var(--radius);
  font-size:0.95rem; font-weight:700; cursor:pointer;
  display:flex; align-items:center; justify-content:center; gap:8px;
  font-family:'Inter',sans-serif; transition:transform 0.1s, opacity 0.15s;
  letter-spacing:0.2px; margin-bottom:12px;
}
.btn-primary:active { transform:scale(0.99); opacity:0.9; }
.btn-accent {
  width:100%; padding:15px;
  background:linear-gradient(135deg,#6366f1,#8b5cf6);
  color:#fff; border:none; border-radius:var(--radius);
  font-size:0.95rem; font-weight:700; cursor:pointer;
  display:flex; align-items:center; justify-content:center; gap:8px;
  font-family:'Inter',sans-serif; transition:transform 0.1s, opacity 0.15s;
  box-shadow:0 4px 20px rgba(99,102,241,0.35); margin-bottom:12px;
  letter-spacing:0.2px;
}

.panel-visible { display: block !important; }
.panel-flex { display: flex !important; }


.btn-accent:active { transform:scale(0.99); opacity:0.9; }
.btn-ghost {
  background:var(--bg); border:none; border-radius:var(--radius-sm);
  padding:10px 16px; cursor:pointer; font-size:0.83rem; font-weight:600;
  color:var(--text2); display:flex; align-items:center; gap:6px;
  font-family:'Inter',sans-serif; transition:background 0.15s;
}
.btn-ghost:hover { background:#e5e5ea; }
.btn-icon {
  background:var(--accent); color:#fff; border:none; border-radius:10px;
  padding:0 14px; height:40px; cursor:pointer; font-size:0.82rem;
  font-weight:600; white-space:nowrap; display:flex; align-items:center;
  gap:5px; font-family:'Inter',sans-serif; transition:opacity 0.15s; flex-shrink:0;
}
.btn-icon:active { opacity:0.85; }

/* ─── LISTS ─── */
.list-wrap {
  background:var(--bg); border-radius:var(--radius-sm);
  max-height:190px; overflow-y:auto; margin-top:6px;
}
.list-item {
  display:flex; align-items:center; justify-content:space-between;
  padding:10px 12px; border-bottom:1px solid var(--border);
  font-size:0.84rem; color:var(--text);
}
.list-item:last-child { border-bottom:none; }
.list-item .rm { background:none; border:none; cursor:pointer; color:var(--text3); display:flex; padding:2px; transition:color 0.1s; }
.list-item .rm:hover { color:var(--red); }
.list-empty { padding:18px; color:var(--text3); font-size:0.82rem; text-align:center; }
.input-row { display:flex; gap:8px; align-items:flex-end; margin-bottom:6px; }
.input-row input { flex:1; margin:0; }

/* ─── BADGE ─── */
.badge { display:inline-flex; align-items:center; background:#ede9fe; color:var(--accent); border-radius:20px; padding:2px 10px; font-size:0.7rem; font-weight:700; margin-left:6px; }
.badge-green { background:#dcfce7; color:#16a34a; }
.badge-red { background:#fee2e2; color:var(--red); }
.badge-orange { background:#fff7ed; color:#ea580c; }

/* ─── CODE OUTPUT ─── */
.code-wrap { background:#ffffff; border-radius:var(--radius); overflow:hidden; box-shadow:var(--shadow-md); margin-bottom:12px; border:1.5px solid #e5e7eb; }
.code-header { display:flex; align-items:center; justify-content:space-between; padding:14px 18px; border-bottom:1px solid #e5e7eb; background:#f9fafb; gap:8px; flex-wrap:wrap; }
.code-header span { color:#374151; font-size:0.78rem; font-weight:700; display:flex; align-items:center; gap:7px; }
.code-header span svg { width:13px; height:13px; color:#6366f1; }
.copy-btn { background:#ffffff; color:#374151; border:1.5px solid #d1d5db; border-radius:8px; padding:6px 14px; cursor:pointer; font-size:0.77rem; font-weight:600; display:flex; align-items:center; gap:6px; font-family:'Inter',sans-serif; transition:all 0.15s; }
.copy-btn:hover { background:#f3f4f6; border-color:#6366f1; color:#6366f1; }
.copy-btn.copied { background:#f0fdf4; color:#16a34a; border-color:#16a34a; }
pre.code-box { color:#1e293b; background:#ffffff; font-family:'Courier New',monospace; font-size:0.74rem; padding:20px; overflow-x:auto; white-space:pre; line-height:1.75; margin:0; max-height:520px; overflow-y:auto; }

/* ─── INFO BOX ─── */
.info-box { background:#f0f9ff; border:1px solid #bae6fd; border-radius:12px; padding:10px 13px; display:flex; gap:8px; align-items:flex-start; margin-bottom:12px; }
.info-box svg { width:13px; height:13px; color:#0284c7; flex-shrink:0; margin-top:1px; }
.info-box p { font-size:0.74rem; color:#0369a1; line-height:1.55; }
.warn-box { background:#fff7ed; border:1px solid #fed7aa; border-radius:12px; padding:10px 13px; display:flex; gap:8px; align-items:flex-start; margin-bottom:12px; }
.warn-box svg { width:13px; height:13px; color:#ea580c; flex-shrink:0; margin-top:1px; }
.warn-box p { font-size:0.74rem; color:#9a3412; line-height:1.55; }

/* ─── PROXY AREA ─── */
.proxy-raw {
  width:100%; background:var(--bg); border:1.5px solid transparent;
  border-radius:var(--radius-sm); padding:12px; font-size:0.76rem;
  font-family:'Courier New',monospace; color:var(--text);
  outline:none; min-height:130px; resize:vertical; line-height:1.8;
  transition:border 0.15s;
}
.proxy-raw:focus { border-color:var(--accent); box-shadow:0 0 0 3px rgba(99,102,241,0.12); background:#fff; }

/* ─── QUICK ACTION ─── */
.quick-actions { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:12px; }
.qa-btn {
  background:var(--surface); border-radius:var(--radius-sm);
  padding:16px; display:flex; flex-direction:column; align-items:flex-start;
  gap:10px; cursor:pointer; box-shadow:var(--shadow);
  border:none; font-family:'Inter',sans-serif; text-align:left;
  transition:transform 0.15s, box-shadow 0.15s;
}
.qa-btn:active { transform:scale(0.97); }
.qa-icon { width:38px; height:38px; border-radius:11px; display:flex; align-items:center; justify-content:center; }
.qa-btn span { font-size:0.82rem; font-weight:700; color:var(--text); }
.qa-btn p { font-size:0.7rem; color:var(--text2); font-weight:500; margin-top:-6px; }

/* ─── RECENT ACTIVITY ─── */
.activity-item { display:flex; align-items:center; gap:13px; padding:12px 0; border-bottom:1px solid var(--border); }
.activity-item:last-child { border-bottom:none; }
.activity-icon { width:38px; height:38px; border-radius:11px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.activity-info { flex:1; }
.activity-info h4 { font-size:0.84rem; font-weight:600; color:var(--text); margin-bottom:2px; }
.activity-info p { font-size:0.72rem; color:var(--text2); }
.activity-time { font-size:0.7rem; color:var(--text3); font-weight:500; }

/* ─── ADS ─── */
.ad-unit-card { background:var(--surface); border-radius:var(--radius); overflow:hidden; margin-bottom:12px; box-shadow:var(--shadow); }
.ad-unit-header { padding:14px 18px; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid var(--border); }
.ad-unit-header h3 { font-size:0.9rem; font-weight:700; color:var(--text); display:flex; align-items:center; gap:8px; }
.ad-unit-body { padding:14px 18px; }
.ad-placement { display:flex; align-items:center; justify-content:space-between; padding:10px 0; border-bottom:1px solid var(--border); }
.ad-placement:last-child { border-bottom:none; }
.ad-placement-left { display:flex; align-items:center; gap:10px; }
.ad-placement-icon { width:32px; height:32px; border-radius:9px; background:#f0f0ff; display:flex; align-items:center; justify-content:center; }
.ad-placement-icon svg { width:15px; height:15px; color:var(--accent); }
.ad-placement h4 { font-size:0.82rem; font-weight:600; color:var(--text); }
.ad-placement p { font-size:0.7rem; color:var(--text2); }
.toggle-switch { position:relative; width:44px; height:26px; }
.toggle-switch input { opacity:0; width:0; height:0; }
.toggle-slider {
  position:absolute; inset:0; background:#e5e5ea; border-radius:99px;
  cursor:pointer; transition:0.2s;
}
.toggle-slider:before {
  content:''; position:absolute; width:20px; height:20px;
  left:3px; top:3px; background:#fff; border-radius:50%;
  transition:0.2s; box-shadow:0 1px 4px rgba(0,0,0,0.2);
}
.toggle-switch input:checked + .toggle-slider { background:var(--green); }
.toggle-switch input:checked + .toggle-slider:before { transform:translateX(18px); }

/* ─── SETTINGS ─── */
.settings-group { background:var(--surface); border-radius:var(--radius); overflow:hidden; margin-bottom:12px; box-shadow:var(--shadow); }
.settings-row { display:flex; align-items:center; justify-content:space-between; padding:14px 18px; border-bottom:1px solid var(--border); cursor:pointer; transition:background 0.1s; }
.settings-row:last-child { border-bottom:none; }
.settings-row:active { background:var(--bg); }
.settings-row-left { display:flex; align-items:center; gap:13px; }
.settings-icon { width:32px; height:32px; border-radius:9px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.settings-icon svg { width:15px; height:15px; color:#fff; }
.settings-row h4 { font-size:0.88rem; font-weight:600; color:var(--text); }
.settings-row p { font-size:0.72rem; color:var(--text2); }
.settings-row svg.chevron { width:16px; height:16px; color:var(--text3); }

/* ─── SECTION TITLE ─── */
.section-title { font-size:1.1rem; font-weight:800; color:var(--text); letter-spacing:-0.3px; margin:18px 0 10px; }

/* ─── IMG GRID ─── */
.img-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(90px,1fr)); gap:8px; margin-top:10px; }
.img-card { border-radius:12px; overflow:hidden; background:var(--bg); position:relative; }
.img-card img { width:100%; height:80px; object-fit:cover; display:block; }
.img-card .img-info { padding:5px 7px; font-size:0.65rem; color:var(--text2); word-break:break-all; line-height:1.3; }
.img-card .rm-btn { position:absolute; top:5px; right:5px; background:rgba(0,0,0,0.5); border:none; border-radius:50%; width:22px; height:22px; color:#fff; cursor:pointer; display:flex; align-items:center; justify-content:center; }
.img-card .rm-btn svg { width:11px; height:11px; }
.img-upload-area { border:2px dashed #d1d5db; border-radius:var(--radius-sm); padding:22px; text-align:center; cursor:pointer; transition:all 0.15s; background:var(--bg); }
.img-upload-area:hover { border-color:var(--accent); background:#f5f3ff; }
.img-upload-area input { display:none; }
.img-upload-area p { font-size:0.8rem; color:var(--text3); }
.img-upload-area p.up-label { font-weight:600; color:var(--accent); margin-bottom:2px; }

/* ─── DOMAIN LIST ─── */
.domain-chip { background:var(--bg); border-radius:10px; padding:9px 12px; font-size:0.82rem; display:flex; align-items:center; justify-content:space-between; gap:8px; margin-bottom:6px; }
.domain-chip a { color:var(--accent); text-decoration:none; font-weight:500; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; flex:1; }
.domain-chip button { background:none; border:none; cursor:pointer; color:var(--text3); display:flex; align-items:center; transition:color 0.1s; }
.domain-chip button:hover { color:var(--red); }

/* ─── HINT ─── */
.hint { font-size:0.71rem; color:var(--text3); margin-top:4px; display:flex; align-items:center; gap:4px; }

/* ─── SCROLLBAR ─── */
::-webkit-scrollbar { width:4px; }
::-webkit-scrollbar-track { background:transparent; }
::-webkit-scrollbar-thumb { background:#d1d5db; border-radius:99px; }
</style>
</head>
<body>

<!-- ════════ SPLASH ════════ -->
<div id="splash" style="position:fixed;inset:0;z-index:9999;background:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0;">
  <div style="position:relative;text-align:center;">
    <div id="splashText" style="font-size:3rem;font-weight:900;color:#000;letter-spacing:-2px;opacity:0;transform:scale(0.6);transition:all 0.7s cubic-bezier(0.34,1.56,0.64,1);">BeelzeAds</div>
    <div id="splashSub" style="font-size:0.8rem;color:#aaa;font-weight:500;letter-spacing:3px;text-transform:uppercase;margin-top:6px;opacity:0;transition:opacity 0.5s ease 0.5s;">Mail & Advertising Platform</div>
    <div style="width:40px;height:3px;background:#000;border-radius:99px;margin:20px auto 0;transform:scaleX(0);transition:transform 0.6s ease 0.3s;" id="splashLine"></div>
  </div>
</div>

<!-- ════════ APP ════════ -->
<div id="app" style="display:none;flex-direction:column;min-height:100vh;padding-bottom:90px;">

  <!-- TOP BAR -->
  <div class="topbar" id="topbar">
    <div class="topbar-left">
      <h1 id="pageTitle">Dashboard</h1>
      <p id="pageSubtitle">Good morning, Beelze 👋</p>
    </div>
    
    <div class="topbar-right">
      <!-- Mail Filter Toggle -->
      <button onclick="openFilter()" style="position:relative;width:36px;height:36px;border-radius:50%;background:#fff;border:1px solid #e5e7eb;box-shadow:0 1px 6px rgba(0,0,0,0.08);display:flex;align-items:center;justify-content:center;cursor:pointer;padding:0;transition:box-shadow 0.2s;" title="Mail Filter">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
          <path d="M2 6L12 13L22 6V4L12 11L2 4V6Z" fill="#EA4335"/>
          <path d="M2 6L2 18C2 19.1 2.9 20 4 20H9V13L2 6Z" fill="#34A853"/>
          <path d="M22 6V18C22 19.1 21.1 20 20 20H15V13L22 6Z" fill="#4285F4"/>
          <path d="M9 20H15V13L9 13V20Z" fill="#FBBC05"/>
        </svg>
        <div style="position:absolute;bottom:-1px;right:-1px;width:14px;height:14px;background:#6366f1;border-radius:50%;display:flex;align-items:center;justify-content:center;border:1.5px solid #fff;">
          <i data-lucide="filter" style="width:8px;height:8px;color:#fff;"></i>
        </div>
      </button>
      
      
      <!-- Mailgun Button -->
      <button onclick="openMailgun()" style="position:relative;width:36px;height:36px;border-radius:50%;background:#fff;border:1px solid #e5e7eb;box-shadow:0 1px 6px rgba(0,0,0,0.08);display:flex;align-items:center;justify-content:center;cursor:pointer;padding:0;transition:box-shadow 0.2s;" title="Mailgun Sender">
        <svg viewBox="0 0 36 36" width="20" height="20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="18" cy="18" r="18" fill="#F06B26"/>
          <path d="M18 8C12.477 8 8 12.477 8 18c0 5.523 4.477 10 10 10 1.8 0 3.49-.476 4.95-1.308l-1.6-2.308A7.04 7.04 0 0 1 18 25c-3.866 0-7-3.134-7-7s3.134-7 7-7c3.354 0 6.163 2.356 6.845 5.5H22v5h5V18C27 12.477 22.523 8 18 8Z" fill="white"/>
          <circle cx="18" cy="18" r="3" fill="white"/>
        </svg>
        <div style="position:absolute;bottom:-1px;right:-1px;width:14px;height:14px;background:#f06b26;border-radius:50%;display:flex;align-items:center;justify-content:center;border:1.5px solid #fff;">
          <i data-lucide="send" style="width:7px;height:7px;color:#fff;"></i>
        </div>
      </button>

      <!-- Guide / Info Button -->
      <button onclick="openGuide()" style="position:relative;width:36px;height:36px;border-radius:50%;background:#fff;border:1px solid #e5e7eb;box-shadow:0 1px 6px rgba(0,0,0,0.08);display:flex;align-items:center;justify-content:center;cursor:pointer;padding:0;transition:box-shadow 0.2s;" title="Deliverability Guide">
        <div style="width:22px;height:22px;background:linear-gradient(135deg,#6366f1,#8b5cf6);border-radius:50%;display:flex;align-items:center;justify-content:center;">
          <i data-lucide="book-open" style="width:11px;height:11px;color:#fff;"></i>
        </div>
      </button>
      
      
      <div class="status-dot"></div>
      <div class="topbar-avatar">
      
        <img src="https://media.base44.com/images/public/69aeee89baab381c29ae8d31/bb2a57956_Screenshot_20260406_015157_Gallery.jpg"/>
      </div>
    </div>
  </div>

  <!-- ═══ PAGE: DASHBOARD ═══ -->
  <div class="page active" id="pageDashboard" style="padding-top:8px">

  

    <div class="section-title">Quick Actions</div>
    <div class="quick-actions">
      <button class="qa-btn" onclick="goPage('compose')">
        <div class="qa-icon" style="background:#ede9fe"><i data-lucide="pencil" style="width:18px;height:18px;color:#6366f1"></i></div>
        <span>New Campaign</span>
        <p>Compose & send</p>
      </button>
      <button class="qa-btn" onclick="goPage('config')">
        <div class="qa-icon" style="background:#dcfce7"><i data-lucide="settings-2" style="width:18px;height:18px;color:#16a34a"></i></div>
        <span>Setup</span>
        <p>Accounts & proxies</p>
      </button>
      <button class="qa-btn" onclick="goPage('ads')">
        <div class="qa-icon" style="background:#dbeafe"><i data-lucide="megaphone" style="width:18px;height:18px;color:#2563eb"></i></div>
        <span>Advertising</span>
        <p>Ad placements</p>
      </button>
      <button class="qa-btn" onclick="goPage('settings')">
        <div class="qa-icon" style="background:#fff7ed"><i data-lucide="sliders-horizontal" style="width:18px;height:18px;color:#ea580c"></i></div>
        <span>Settings</span>
        <p>App preferences</p>
      </button>
    </div>

    <div class="section-title">Recent Activity</div>
    <div class="card" style="padding:2px 18px">
      <div class="activity-item">
        <div class="activity-icon" style="background:#ede9fe"><i data-lucide="send" style="width:16px;height:16px;color:#6366f1"></i></div>
        <div class="activity-info">
          <h4>Campaign Generated</h4>
          <p>Python script ready for Colab</p>
        </div>
        <span class="activity-time">Just now</span>
      </div>
      <div class="activity-item">
        <div class="activity-icon" style="background:#dcfce7"><i data-lucide="shield-check" style="width:16px;height:16px;color:#16a34a"></i></div>
        <div class="activity-info">
          <h4>Proxies Active</h4>
          <p>IP rotation enabled</p>
        </div>
        <span class="activity-time">Ready</span>
      </div>
      <div class="activity-item">
        <div class="activity-icon" style="background:#dbeafe"><i data-lucide="megaphone" style="width:16px;height:16px;color:#2563eb"></i></div>
        <div class="activity-info">
          <h4>Ads Platform</h4>
          <p>Adsterra units configured</p>
        </div>
        <span class="activity-time">Live</span>
      </div>
    </div>

  </div>

  <!-- ═══ PAGE: COMPOSE ═══ -->
  <div class="page" id="pageCompose" style="padding-top:8px">
    <div class="section-title">New Campaign</div>

    <!-- COMPOSE CARD (iPhone mail style) -->
    <div class="card" style="padding:0 18px">
      <div class="compose-field">
        <label>Subject</label>
        <input id="cSubject" placeholder="Email subject line…"/>
      </div>
      <div class="compose-field" style="align-items:center">
        <label>Mode</label>
        <div style="flex:1">
          <div class="pill-toggle" style="margin-bottom:0">
            <button class="pill-btn active" id="modeBcc" onclick="setMode('bcc',this)">
              <i data-lucide="eye-off" style="width:13px;height:13px"></i> BCC
            </button>
            <button class="pill-btn" id="modeInd" onclick="setMode('individual',this)">
              <i data-lucide="send" style="width:13px;height:13px"></i> Individual
            </button>
          </div>
        </div>
      </div>
      <div class="compose-body">
        <textarea id="cBody" placeholder="Write your message here…&#10;&#10;Use {name} to personalise."></textarea>
      </div>
    </div>
    
    

        <!-- IMAGES (under message) -->
    <div class="card">
      <div class="card-header" style="cursor:pointer;user-select:none;" onclick="toggleImgPanel()" id="imgCardHeader">
        <div style="display:flex;align-items:center;gap:8px;">
          <i data-lucide="camera" style="width:14px;height:14px;color:var(--accent)"></i>
          <span style="font-size:0.7rem;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:0.8px;">Add Images</span>
        </div>
        <i data-lucide="chevron-down" id="imgChevron" style="width:15px;height:15px;color:var(--text3);transition:transform 0.2s;"></i>
      </div>

      <div id="imgPanel" style="display:none;">
        <!-- Two options -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;padding:14px 18px 0;">
          <button onclick="document.getElementById('imgInput').click()" style="background:var(--bg);border:1.5px dashed #d1d5db;border-radius:12px;padding:18px 10px;display:flex;flex-direction:column;align-items:center;gap:8px;cursor:pointer;font-family:'Inter',sans-serif;transition:border-color 0.15s;" onmouseenter="this.style.borderColor='var(--accent)'" onmouseleave="this.style.borderColor='#d1d5db'">
            <i data-lucide="image-plus" style="width:22px;height:22px;color:var(--accent)"></i>
            <span style="font-size:0.78rem;font-weight:700;color:var(--text)">Upload Photo</span>
            <span style="font-size:0.68rem;color:var(--text3)">Auto-hosted on ImgBB</span>
            <input type="file" id="imgInput" accept="image/*" multiple onchange="uploadImages(this.files)" style="display:none"/>
          </button>
          <button onclick="toggleUrlInput()" style="background:var(--bg);border:1.5px dashed #d1d5db;border-radius:12px;padding:18px 10px;display:flex;flex-direction:column;align-items:center;gap:8px;cursor:pointer;font-family:'Inter',sans-serif;transition:border-color 0.15s;" onmouseenter="this.style.borderColor='var(--accent)'" onmouseleave="this.style.borderColor='#d1d5db'">
            <i data-lucide="link-2" style="width:22px;height:22px;color:var(--accent)"></i>
            <span style="font-size:0.78rem;font-weight:700;color:var(--text)">Paste URL</span>
            <span style="font-size:0.68rem;color:var(--text3)">Direct image link</span>
          </button>
        </div>

        <!-- URL input (hidden until clicked) -->
        <div id="urlInputWrap" style="display:none;padding:12px 18px 0;">
          <div style="display:flex;gap:8px;align-items:flex-end;">
            <div style="flex:1"><label>Image URL</label><input id="directImgUrl" placeholder="https://i.ibb.co/yourimage.jpg"/></div>
            <button class="btn-icon" onclick="addDirectUrl()"><i data-lucide="link" style="width:12px;height:12px"></i></button>
          </div>
        </div>

        <div id="uploadStatus" style="padding:0 18px;margin-top:8px;"></div>
        <div class="img-grid" id="imgGrid" style="padding:0 18px 14px;margin-top:8px;"></div>
      </div>
    </div>

    <!-- SIGN OFF -->
    <div class="card">
      <div class="card-header"><i data-lucide="pen-line"></i> Sign-off</div>
      <div class="field"><label>Sender Name</label><input id="cSenderName" placeholder="e.g. BeelzeAds Team"/></div>
    </div>

    <!-- BATCH SETTINGS -->
    <div class="card">
      <div class="card-header"><i data-lucide="sliders-horizontal"></i> Sending Settings</div>
      <div class="grid2">
        <div class="field"><label>BCC Batch Size</label><input id="cBatchSize" value="50" type="number" min="1" max="500"/></div>
        <div class="field"><label>Emails/Account</label><input id="cEmailsPerAcc" value="100" type="number" min="1" max="500"/></div>
      </div>
      <div class="hint" style="margin-bottom:8px"><i data-lucide="info" style="width:11px;height:11px;color:var(--accent)"></i> Batch delay: random 40–120s · Account switch: random 20–50s · IP rotates every send</div>
    </div>

    <!-- RECIPIENTS -->
    <div class="card">
      <div class="card-header"><i data-lucide="users-round"></i> Recipients <span class="badge" id="countBadge">0 emails</span></div>
      <div class="input-row">
        <input id="emailInput" placeholder="Paste emails separated by commas or newlines…"/>
        <button class="btn-icon" onclick="addEmails()"><i data-lucide="plus" style="width:13px;height:13px"></i></button>
      </div>
      <p class="hint" style="margin-bottom:8px"><i data-lucide="lightbulb" style="width:11px;height:11px;color:#f59e0b"></i> Paste bulk: email1@x.com, email2@x.com</p>
      <div class="list-wrap" id="emailList" style="max-height:220px"><div class="list-empty">No recipients added yet</div></div>
      <button class="btn-ghost" onclick="emails=[];renderEmails()" style="margin-top:8px;width:100%;justify-content:center;color:var(--red)">
        <i data-lucide="trash-2" style="width:13px;height:13px"></i> Clear All
      </button>
    </div>

    <!-- SENDER ACCOUNTS -->
    <div class="card">
  <div class="card-header"><i data-lucide="users"></i> Sender Accounts <span class="badge" id="accountBadge">0</span></div>
  <div style="display:flex;gap:8px;align-items:center;margin-bottom:10px;">
    <input id="accountInput" placeholder="email@gmail.com - apppassword" style="flex:1;background:var(--bg);border:1.5px solid transparent;border-radius:var(--radius-sm);padding:12px 14px;font-size:0.88rem;font-family:'Inter',sans-serif;color:var(--text);outline:none;transition:border 0.15s;"/>
    <button class="btn-icon" onclick="addAccount()"><i data-lucide="plus" style="width:13px;height:13px"></i></button>
  </div>
  <p class="hint" style="margin-bottom:8px"><i data-lucide="lightbulb" style="width:11px;height:11px;color:#f59e0b"></i> Paste all accounts at once then click +</p>
  <div class="list-wrap" id="accountList"><div class="list-empty">No accounts added</div></div>
</div>

    <!-- PROXY IPs -->
    <div class="card">
  <div class="card-header"><i data-lucide="shield"></i> Proxy IPs <span class="badge" id="proxyBadge">0</span></div>
  <div style="display:flex;gap:8px;align-items:center;margin-bottom:8px;">
    <input id="proxyRaw" placeholder="IP: x.x.x.x - PORT: 1234 - USERNAME: user - PASSWORD: pass" oninput="parseProxies()" style="flex:1;background:var(--bg);border:1.5px solid transparent;border-radius:var(--radius-sm);padding:12px 14px;font-size:0.82rem;font-family:'Courier New',monospace;color:var(--text);outline:none;transition:border 0.15s;"/>
    <button class="btn-icon" onclick="parseProxies()"><i data-lucide="plus" style="width:13px;height:13px"></i></button>
  </div>
  <p class="hint" id="proxyHint" style="margin-bottom:8px"><i data-lucide="info" style="width:11px;height:11px"></i> Paste one or many — parsed automatically</p>
  <div class="list-wrap" id="proxyList" style="max-height:160px;margin-bottom:10px;"></div>
  <div class="field" style="margin-bottom:0">
    <label>Proxy Protocol</label>
    <select id="proxyType"><option value="socks5">SOCKS5</option><option value="socks4">SOCKS4</option><option value="http">HTTP</option></select>
  </div>
</div>



    <!-- LINKS IN EMAIL -->
    <div class="card">
      <div class="card-header"><i data-lucide="link-2"></i> Call-to-Action Links</div>
      <div style="display:flex;gap:8px;align-items:flex-end;margin-bottom:8px">
        <div style="flex:1"><label>Label</label><input id="dText" placeholder="e.g. Shop Now"/></div>
        <div style="flex:2"><label>URL</label><input id="dUrl" placeholder="https://darkmasterstore.co.za"/></div>
        <button class="btn-icon" onclick="addDomain()" style="flex-shrink:0"><i data-lucide="plus" style="width:13px;height:13px"></i></button>
      </div>
      <div id="domainList"></div>
    </div>

    

    <!-- GENERATE -->
            <button onclick="generate()" style="width:100%;padding:16px 20px;background:#fff;color:#000;border:2px solid #e5e5ea;border-radius:20px;font-size:1rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:14px;font-family:'Inter',sans-serif;margin-bottom:12px;transition:all 0.15s;box-shadow:0 2px 12px rgba(0,0,0,0.06);" onmousedown="this.style.transform='scale(0.98)';this.style.boxShadow='0 1px 6px rgba(0,0,0,0.08)'" onmouseup="this.style.transform='scale(1)'">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="28" height="28" rx="8" fill="#3776AB"/>
        <path d="M14 6C10.5 6 10.5 7.5 10.5 7.5V9H14V9.5H8.5C8.5 9.5 6 9.8 6 13C6 16.2 8.2 16 8.2 16H9.5V14.4C9.5 14.4 9.4 12 12 12H16C16 12 18 12.1 18 10.1V7.9C18 7.9 18.1 6 14 6ZM12.5 8C12.5 7.4 13 7 13.5 7C14 7 14.5 7.4 14.5 8C14.5 8.6 14 9 13.5 9C13 9 12.5 8.6 12.5 8Z" fill="#FFD43B"/>
        <path d="M14 22C17.5 22 17.5 20.5 17.5 20.5V19H14V18.5H19.5C19.5 18.5 22 18.2 22 15C22 11.8 19.8 12 19.8 12H18.5V13.6C18.5 13.6 18.6 16 16 16H12C12 16 10 15.9 10 17.9V20.1C10 20.1 9.9 22 14 22ZM15.5 20C15.5 20.6 15 21 14.5 21C14 21 13.5 20.6 13.5 20C13.5 19.4 14 19 14.5 19C15 19 15.5 19.4 15.5 20Z" fill="#FFD43B"/>
      </svg>
      <div style="text-align:left;">
        <div style="font-size:0.95rem;font-weight:700;color:#000;">Generate Python Script</div>
        <div style="font-size:0.72rem;color:#aaa;font-weight:500;">Proxy · IP Rotation · BCC Blast</div>
      </div>
      <i data-lucide="chevron-right" style="width:18px;height:18px;color:#ccc;margin-left:auto"></i>
    </button>
      
    <div id="outputSection" style="display:none">
      <div class="code-wrap">
        <div class="code-header">
          <span><i data-lucide="terminal"></i> Python Script — Paste into Google Colab</span>
          <button class="copy-btn" id="copyBtn" onclick="copyCode()"><i data-lucide="copy" style="width:12px;height:12px"></i> Copy</button>
        </div>
        <pre class="code-box" id="codeOutput"></pre>
      </div>
      
      <button onclick="openInColab()" style="width:100%;padding:16px;background:#ff6b35;color:#fff;border:none;border-radius:18px;font-size:0.92rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:10px;margin-top:12px;margin-bottom:10px;font-family:'Inter',sans-serif;box-shadow:0 4px 20px rgba(255,107,53,0.35);">
        <i data-lucide="play" style="width:17px;height:17px"></i> Copy Script & Open Google Colab
      </button>
      
      <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:12px;padding:13px 15px;margin-bottom:12px;display:flex;gap:10px;align-items:flex-start">
        <i data-lucide="check-circle-2" style="width:15px;height:15px;color:#16a34a;flex-shrink:0;margin-top:1px"></i>
        <p style="font-size:0.78rem;color:#15803d;line-height:1.55">Script generated! Open <strong>colab.research.google.com</strong> → New Notebook → paste → ▶ Run</p>
      </div>
    </div>

  </div>

  <!-- ═══ PAGE: CONFIG ═══ -->
  <div class="page" id="pageConfig" style="padding-top:8px">
    <div class="section-title">Sender Accounts</div>

    <div class="card">
      <div class="card-header"><i data-lucide="users"></i> Accounts Pool <span class="badge" id="accountBadge">0</span></div>
      <div class="info-box">
        <i data-lucide="info"></i>
        <p>Format: <strong>email@gmail.com - apppassword</strong> — one per line</p>
      </div>
      <div class="input-row">
        <textarea id="accountInput" rows="4" style="width:100%;background:var(--bg);border:1.5px solid transparent;border-radius:var(--radius-sm);padding:12px;font-size:0.8rem;font-family:'Courier New',monospace;color:var(--text);outline:none;resize:vertical;line-height:1.8;transition:border 0.15s;" placeholder="Paste all at once — any format:&#10;email@gmail.com-apppassword&#10;email@gmail.com - apppassword&#10;email1, email2 on same line — all work"></textarea>
        <button class="btn-icon" onclick="addAccount()"><i data-lucide="plus" style="width:13px;height:13px"></i></button>
      </div>
      <div class="list-wrap" id="accountList"><div class="list-empty">No accounts added</div></div>
    </div>

    <div class="section-title">Proxy Configuration</div>

    <div class="card">
      <div class="card-header"><i data-lucide="shield"></i> Proxy IPs <span class="badge" id="proxyBadge">0</span></div>
      <div class="info-box">
        <i data-lucide="info"></i>
        <p>Accepted format:<br/>
        <strong>IP: x.x.x.x - PORT: 1234 - USERNAME: user - PASSWORD: pass</strong><br/>
        or <strong>ip:port:user:pass</strong> — paste all at once.</p>
      </div>
      <div class="field">
        <label>Paste Proxy List</label>
        <textarea class="proxy-raw" id="proxyRaw" placeholder="IP: 38.154.203.95 - PORT: 5863 - USERNAME: lwlvfjpm - PASSWORD: qz3oatatml1n&#10;IP: 198.105.121.200 - PORT: 6462 - USERNAME: lwlvfjpm - PASSWORD: qz3oatatml1n&#10;..." oninput="parseProxies()"></textarea>
        <p class="hint" id="proxyHint"><i data-lucide="info" style="width:11px;height:11px"></i> Proxies parsed automatically as you type</p>
      </div>
      <div class="field" style="margin-bottom:0">
        <label>Proxy Protocol</label>
        <select id="proxyType">
          <option value="socks5">SOCKS5 (Recommended)</option>
          <option value="socks4">SOCKS4</option>
          <option value="http">HTTP</option>
        </select>
      </div>
    </div>

    <div class="section-title">SMTP Settings</div>

    <div class="card">
      <div class="card-header"><i data-lucide="server"></i> SMTP Server</div>
      <div class="grid2">
        <div class="field"><label>Host</label><input id="smtpHost" value="smtp.gmail.com"/></div>
        <div class="field"><label>Port</label><input id="smtpPort" value="25" type="number"/></div>
      </div>
      <div class="info-box" style="margin-bottom:0">
        <i data-lucide="info"></i>
        <p>Use Gmail <strong>App Passwords</strong> — not your regular password. Enable 2-Step Verification first.</p>
      </div>
    </div>

  </div>

  <!-- ═══ PAGE: RECIPIENTS ═══ -->
  <div class="page" id="pageRecipients" style="padding-top:8px">
    <div class="section-title">Recipients <span class="badge" id="recipientBadge">0 emails</span></div>

    <div class="card">
      <div class="card-header"><i data-lucide="users-round"></i> Email List</div>
      <div class="input-row">
        <input id="emailInput" placeholder="Paste emails separated by commas or newlines…"/>
        <button class="btn-icon" onclick="addEmails()"><i data-lucide="plus" style="width:13px;height:13px"></i></button>
      </div>
      <p class="hint" style="margin-bottom:10px"><i data-lucide="lightbulb" style="width:11px;height:11px;color:#f59e0b"></i> Paste multiple: email1@x.com, email2@x.com</p>
      <div class="list-wrap" id="emailList" style="max-height:360px"><div class="list-empty">No emails added yet</div></div>
    </div>

    <button class="btn-ghost" onclick="emails=[];renderEmails()" style="width:100%;justify-content:center;color:var(--red);margin-bottom:12px">
      <i data-lucide="trash-2" style="width:14px;height:14px"></i> Clear All Recipients
    </button>
  </div>

<!-- ═══ PAGE: ADS ═══ -->
  <div class="page" id="pageAds" style="padding-top:8px">
    <div class="section-title">BeelzeAds — Banner Manager</div>

    <!-- ADD BANNER CARD -->
    <div class="card">
      <div class="card-header"><i data-lucide="building-2"></i> Add Business to Banner Rotation</div>
      <p style="font-size:0.78rem;color:#888;margin-bottom:14px;line-height:1.6;">Each business rotates on the banner every 5 minutes. Its images rotate every 5 seconds.</p>

      <div class="field"><label>Business Name</label><input id="bizName" placeholder="e.g. Pick n Pay"/></div>
      <div class="field"><label>Slogan</label><input id="bizSlogan" placeholder="e.g. Fresher for longer"/></div>
      <div class="field"><label>Website URL</label><input id="bizUrl" type="url" placeholder="https://www.picknpay.co.za"/></div>
      <div class="field"><label>Phone (optional)</label><input id="bizPhone" type="tel" placeholder="e.g. 0800123456"/></div>

      <label style="font-size:0.7rem;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:0.5px;display:block;margin-bottom:8px;">Business Images (add multiple)</label>
      <div style="display:flex;gap:8px;margin-bottom:8px;">
        <input id="bizImgUrlInput" type="url" placeholder="Paste image URL..." style="flex:1;padding:10px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:0.82rem;font-family:'Inter',sans-serif;outline:none;background:var(--bg);"/>
        <button onclick="addBizImgUrl()" style="background:var(--accent);color:#fff;border:none;border-radius:10px;padding:10px 14px;cursor:pointer;font-weight:700;font-size:0.8rem;font-family:'Inter',sans-serif;">Add URL</button>
      </div>
      <label style="display:flex;align-items:center;gap:8px;background:var(--bg);border:1.5px dashed #d1d5db;border-radius:10px;padding:12px 16px;cursor:pointer;font-size:0.8rem;font-weight:600;color:var(--text2);margin-bottom:10px;" onmouseenter="this.style.borderColor='var(--accent)'" onmouseleave="this.style.borderColor='#d1d5db'">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
        Upload Images
        <input type="file" accept="image/*" multiple style="display:none" onchange="uploadBizImages(this.files)"/>
      </label>
      <div id="bizUploadStatus" style="font-size:0.78rem;color:#6366f1;margin-bottom:6px;display:none;">Uploading...</div>
      <div id="bizImgGrid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(80px,1fr));gap:8px;margin-bottom:14px;"></div>

      <div id="bizFormError" style="font-size:0.78rem;color:#ef4444;margin-bottom:8px;display:none;"></div>
      <button onclick="addCampaign()" style="width:100%;padding:13px;background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;border:none;border-radius:11px;font-size:0.9rem;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;display:flex;align-items:center;justify-content:center;gap:8px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
        Add Business to Rotation
      </button>
    </div>


      <label style="font-size:0.78rem;font-weight:600;color:var(--text2);display:block;margin-bottom:6px;">Banner Image</label>
      <div style="display:flex;gap:8px;margin-bottom:10px;">
        <input id="bannerImgUrl" type="url" placeholder="Paste image URL or upload below..." 
          style="flex:1;padding:10px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:0.82rem;font-family:'Inter',sans-serif;background:var(--bg2);color:var(--text1);outline:none;"
          oninput="previewBannerImg()">
        <label style="display:flex;align-items:center;gap:6px;padding:10px 14px;background:var(--bg2);border:1.5px solid var(--border);border-radius:10px;cursor:pointer;font-size:0.8rem;font-weight:600;color:var(--text2);">
          <i data-lucide="upload" style="width:14px;height:14px;"></i> Upload
          <input type="file" accept="image/*" style="display:none" onchange="uploadBannerImg(this)">
        </label>
      </div>

      <div id="bannerImgPreview" style="display:none;margin-bottom:12px;position:relative;">
        <img id="bannerPreviewImg" style="width:100%;height:140px;object-fit:cover;border-radius:10px;border:2px solid var(--border);">
        <button onclick="clearBannerImg()" style="position:absolute;top:6px;right:6px;background:rgba(0,0,0,0.6);border:none;border-radius:50%;width:26px;height:26px;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;">
          <i data-lucide="x" style="width:13px;height:13px;"></i>
        </button>
      </div>
      <div id="bannerUploadStatus" style="font-size:0.78rem;color:#6366f1;margin-bottom:8px;display:none;">Uploading...</div>

      <label style="font-size:0.78rem;font-weight:600;color:var(--text2);display:block;margin-bottom:6px;">Click Destination URL</label>
      <input id="bannerLinkUrl" type="url" placeholder="https://yourapp.com or any link..." 
        style="width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:0.82rem;font-family:'Inter',sans-serif;background:var(--bg2);color:var(--text1);outline:none;margin-bottom:10px;box-sizing:border-box;">

         <label style="font-size:0.78rem;font-weight:600;color:var(--text2);display:block;margin-bottom:6px;">Ad Label (shown as "Sponsored by...")</label>
      <input id="bannerLabel" type="text" placeholder="e.g. StreamX App, Dark Master Store..." 
        style="width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:0.82rem;font-family:'Inter',sans-serif;background:var(--bg2);color:var(--text1);outline:none;margin-bottom:10px;box-sizing:border-box;">

      <label style="font-size:0.78rem;font-weight:600;color:var(--text2);display:block;margin-bottom:6px;">Phone Number (optional — for Call Now ads)</label>
      <input id="bannerPhone" type="tel" placeholder="e.g. 0761234567" 
        style="width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:0.82rem;font-family:'Inter',sans-serif;background:var(--bg2);color:var(--text1);outline:none;margin-bottom:12px;box-sizing:border-box;">

      <div id="bannerFormError" style="font-size:0.78rem;color:#ef4444;margin-bottom:8px;display:none;"></div>

      <button onclick="addBanner()" style="width:100%;padding:12px;background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;border:none;border-radius:10px;font-size:0.88rem;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;display:flex;align-items:center;justify-content:center;gap:8px;">
        <i data-lucide="plus-circle" style="width:16px;height:16px;"></i> Add Banner
      </button>
    </div>

    <!-- LIVE PREVIEW -->
    <div class="section-title">Live Preview</div>
    <div class="card" style="padding:0;overflow:hidden;">
      <div id="bannerPreviewContainer" style="min-height:100px;background:#f3f4f6;display:flex;align-items:center;justify-content:center;color:#9ca3af;font-size:0.8rem;">
        <i data-lucide="image" style="width:24px;height:24px;margin-right:8px;"></i> Your banner preview will appear here
      </div>
      <div id="bannerPreviewLabel" style="padding:8px 14px;font-size:0.72rem;color:#6b7280;display:none;">
        <i data-lucide="external-link" style="width:11px;height:11px;"></i> <span id="bannerPreviewLabelText"></span>
      </div>
    </div>

    <!-- BANNER LIST -->
    <div class="section-title">My Banners (<span id="bannerCount">0</span>)</div>
    <div id="bannerList" style="margin-bottom:16px;">
      <div style="background:var(--bg1);border:1px solid var(--border);border-radius:12px;padding:32px;text-align:center;color:var(--text3);font-size:0.82rem;">
        <i data-lucide="layout-panel-top" style="width:28px;height:28px;color:var(--border);display:block;margin:0 auto 10px;"></i>
        No banners yet — add your first one above
      </div>
    </div>

    
        <!-- ROTATION SETTINGS -->
    <div class="card">
      <div class="card-header"><i data-lucide="settings-2"></i> Banner Settings</div>

      <label style="font-size:0.78rem;font-weight:600;color:var(--text2);display:block;margin-bottom:6px;">Ad Size</label>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px;">
        <button class="size-btn active" onclick="selectSize(this,'xs')" data-size="xs" style="padding:10px;border:2px solid #6366f1;border-radius:10px;background:#ede9fe;color:#6366f1;font-size:0.78rem;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;">
          <i data-lucide="minimize-2" style="width:13px;height:13px;display:block;margin:0 auto 4px;"></i>Extra Small<br><span style="font-size:0.65rem;font-weight:400;color:#6b7280;">80px height</span>
        </button>
        <button class="size-btn" onclick="selectSize(this,'sm')" data-size="sm" style="padding:10px;border:2px solid var(--border);border-radius:10px;background:var(--bg2);color:var(--text2);font-size:0.78rem;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;">
          <i data-lucide="square" style="width:13px;height:13px;display:block;margin:0 auto 4px;"></i>Small<br><span style="font-size:0.65rem;font-weight:400;color:#6b7280;">120px height</span>
        </button>
        <button class="size-btn" onclick="selectSize(this,'md')" data-size="md" style="padding:10px;border:2px solid var(--border);border-radius:10px;background:var(--bg2);color:var(--text2);font-size:0.78rem;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;">
          <i data-lucide="layout-dashboard" style="width:13px;height:13px;display:block;margin:0 auto 4px;"></i>Medium<br><span style="font-size:0.65rem;font-weight:400;color:#6b7280;">200px height</span>
        </button>
        <button class="size-btn" onclick="selectSize(this,'lg')" data-size="lg" style="padding:10px;border:2px solid var(--border);border-radius:10px;background:var(--bg2);color:var(--text2);font-size:0.78rem;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;">
          <i data-lucide="maximize-2" style="width:13px;height:13px;display:block;margin:0 auto 4px;"></i>Large<br><span style="font-size:0.65rem;font-weight:400;color:#6b7280;">300px height</span>
        </button>
      </div>

      <label style="font-size:0.78rem;font-weight:600;color:var(--text2);display:block;margin-bottom:6px;">Banner Style</label>
      <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:14px;">
        <button class="style-btn active" onclick="selectStyle(this,'image-only')" style="padding:10px 14px;border:2px solid #6366f1;border-radius:10px;background:#ede9fe;color:#6366f1;font-size:0.8rem;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;text-align:left;display:flex;align-items:center;gap:8px;">
          <i data-lucide="image" style="width:14px;height:14px;flex-shrink:0;"></i> Image Only <span style="font-size:0.7rem;font-weight:400;color:#6b7280;margin-left:auto;">Click image → opens site</span>
        </button>
        <button class="style-btn" onclick="selectStyle(this,'shop-now')" style="padding:10px 14px;border:2px solid var(--border);border-radius:10px;background:var(--bg2);color:var(--text2);font-size:0.8rem;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;text-align:left;display:flex;align-items:center;gap:8px;">
          <i data-lucide="shopping-bag" style="width:14px;height:14px;flex-shrink:0;"></i> Shop Now Button
        </button>
        <button class="style-btn" onclick="selectStyle(this,'book-now')" style="padding:10px 14px;border:2px solid var(--border);border-radius:10px;background:var(--bg2);color:var(--text2);font-size:0.8rem;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;text-align:left;display:flex;align-items:center;gap:8px;">
          <i data-lucide="calendar-check" style="width:14px;height:14px;flex-shrink:0;"></i> Book Now Button
        </button>
        <button class="style-btn" onclick="selectStyle(this,'place-order')" style="padding:10px 14px;border:2px solid var(--border);border-radius:10px;background:var(--bg2);color:var(--text2);font-size:0.8rem;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;text-align:left;display:flex;align-items:center;gap:8px;">
          <i data-lucide="package" style="width:14px;height:14px;flex-shrink:0;"></i> Place Order Button
        </button>
        <button class="style-btn" onclick="selectStyle(this,'visit-website')" style="padding:10px 14px;border:2px solid var(--border);border-radius:10px;background:var(--bg2);color:var(--text2);font-size:0.8rem;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;text-align:left;display:flex;align-items:center;gap:8px;">
          <i data-lucide="globe" style="width:14px;height:14px;flex-shrink:0;"></i> Visit Website Button
        </button>
      </div>

      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
        <div>
          <div style="font-size:0.85rem;font-weight:600;">Rotate every</div>
          <div style="font-size:0.72rem;color:var(--text3);">Seconds between banner switches</div>
        </div>
        <select id="rotationSpeed" style="padding:8px 12px;border:1.5px solid var(--border);border-radius:8px;font-size:0.85rem;background:var(--bg2);color:var(--text1);font-family:'Inter',sans-serif;">
          <option value="3000">3 seconds</option>
          <option value="5000" selected>5 seconds</option>
          <option value="8000">8 seconds</option>
          <option value="10000">10 seconds</option>
          <option value="15000">15 seconds</option>
        </select>
      </div>
      
            <div style="display:flex;align-items:center;justify-content:space-between;">
        <div>
          <div style="font-size:0.85rem;font-weight:600;">Transition</div>
          <div style="font-size:0.72rem;color:var(--text3);">Banner switch animation</div>
        </div>
        <select id="rotationTransition" style="padding:8px 12px;border:1.5px solid var(--border);border-radius:8px;font-size:0.85rem;background:var(--bg2);color:var(--text1);font-family:'Inter',sans-serif;">
          <option value="fade" selected>Fade</option>
          <option value="slide">Slide</option>
          <option value="none">None</option>
        </select>
      </div>
    </div>
    <!-- GENERATE SCRIPT -->
    <div class="section-title">Generated Embed Script</div>
    <div class="card">
      <div class="card-header"><i data-lucide="code-2"></i> BeelzeAds Banner Script</div>
      <p style="font-size:0.8rem;color:var(--text2);margin-bottom:12px;line-height:1.6;">
        Copy this script and paste it into ANY website or app HTML. Banners rotate automatically. Controlled from BeelzeAds — no need to touch other apps' code again.
      </p>

      <button onclick="generateBannerScript()" style="width:100%;padding:12px;background:linear-gradient(135deg,#059669,#0d9488);color:#fff;border:none;border-radius:10px;font-size:0.88rem;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:12px;">
        <i data-lucide="zap" style="width:16px;height:16px;"></i> Generate Script
      </button>

      <div id="bannerScriptWrap" style="display:none;">
        <div class="code-wrap">
          <div class="code-header">
            <span><i data-lucide="code-2"></i> Paste this in your HTML</span>
            <button class="copy-btn" onclick="copyBannerScript()"><i data-lucide="copy" style="width:12px;height:12px"></i> Copy</button>
          </div>
          <pre class="code-box" id="bannerScriptOutput" style="white-space:pre-wrap;word-break:break-all;font-size:0.72rem;max-height:300px;overflow-y:auto;"></pre>
        </div>
        <div class="warn-box" style="margin-top:10px;margin-bottom:0;">
          <i data-lucide="info"></i>
          <p>This script loads banners from Firebase in real-time. Update banners here — all sites update automatically with no code changes needed.</p>
        </div>
    </div>

  </div> <!-- end pageAds -->

  <!-- ═══ PAGE: SETTINGS ═══ -->
