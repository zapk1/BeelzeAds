        <div style="font-size:0.65rem;font-weight:700;color:#e00;text-transform:uppercase;letter-spacing:1px;">Native Banner Ads</div>
        <div id="gatePkgNativeCheck" style="width:18px;height:18px;border-radius:50%;border:2px solid #ddd;display:flex;align-items:center;justify-content:center;transition:all 0.2s;"></div>
      </div>
      <div style="font-size:1.3rem;font-weight:900;color:#111;letter-spacing:-0.5px;">R100 <span style="font-size:0.78rem;font-weight:500;color:#999;">/ 30 days</span></div>
      <div style="font-size:0.75rem;color:#666;margin-top:6px;line-height:1.55;">100–500 daily views. Rotating banner on real websites. Real eyeballs.</div>
      <div style="margin-top:10px;display:flex;flex-wrap:wrap;gap:6px;">
        <span style="font-size:0.65rem;font-weight:600;background:#fff5f5;color:#e00;padding:3px 10px;border-radius:99px;border:1px solid #ffd0d0;">✓ Auto-rotating</span>
        <span style="font-size:0.65rem;font-weight:600;background:#fff5f5;color:#e00;padding:3px 10px;border-radius:99px;border:1px solid #ffd0d0;">✓ Multiple sites</span>
        <span style="font-size:0.65rem;font-weight:600;background:#fff5f5;color:#e00;padding:3px 10px;border-radius:99px;border:1px solid #ffd0d0;">✓ Click tracking</span>
      </div>
      <button style="margin-top:14px;width:100%;padding:11px;background:#e00;color:#fff;border:none;border-radius:12px;font-size:0.82rem;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;letter-spacing:0.3px;">Select Plan</button>
    </div>

    <!-- AD DETAILS FORM (shown after selection) -->
    <div id="gateFormSection" style="display:none;">
      <div style="font-size:0.65rem;font-weight:700;color:#bbb;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:12px;">Your business details</div>

      <div id="gateProvinceWrap" style="display:none;margin-bottom:10px;">
        <select id="gateProvince" style="width:100%;padding:12px 14px;border:1.5px solid #eee;border-radius:12px;font-size:0.82rem;font-family:'Inter',sans-serif;background:#fff;outline:none;color:#333;">
          <option value="">Select target province...</option>
          <option>Gauteng</option><option>Western Cape</option><option>KwaZulu-Natal</option>
          <option>Eastern Cape</option><option>Limpopo</option><option>Mpumalanga</option>
          <option>North West</option><option>Free State</option><option>Northern Cape</option>
        </select>
      </div>

      <div style="background:#fff;border:1.5px solid #eee;border-radius:16px;padding:16px;margin-bottom:12px;">
        <input id="gateAdName" placeholder="Business / Ad name" style="width:100%;padding:11px 14px;border:1.5px solid #eee;border-radius:10px;font-size:0.82rem;font-family:'Inter',sans-serif;outline:none;margin-bottom:10px;box-sizing:border-box;color:#111;"/>
        <input id="gateAdEmail" type="email" placeholder="Your email address" style="width:100%;padding:11px 14px;border:1.5px solid #eee;border-radius:10px;font-size:0.82rem;font-family:'Inter',sans-serif;outline:none;margin-bottom:10px;box-sizing:border-box;color:#111;"/>
        <input id="gateAdUrl" placeholder="Website URL (optional)" style="width:100%;padding:11px 14px;border:1.5px solid #eee;border-radius:10px;font-size:0.82rem;font-family:'Inter',sans-serif;outline:none;margin-bottom:10px;box-sizing:border-box;color:#111;" onblur="if(this.value&&!this.value.startsWith('http'))this.value='https://'+this.value"/>
        <input id="gateAdPhone" type="tel" placeholder="Phone number (optional)" style="width:100%;padding:11px 14px;border:1.5px solid #eee;border-radius:10px;font-size:0.82rem;font-family:'Inter',sans-serif;outline:none;margin-bottom:10px;box-sizing:border-box;color:#111;"/>

        <!-- IMAGE UPLOAD -->
<div style="margin-bottom:8px;">
  <div style="font-size:0.75rem;font-weight:700;color:#333;margin-bottom:8px;display:flex;align-items:center;gap:6px;">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
    Business Images (add multiple)
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;">
    <button onclick="document.getElementById('gateAdImgInput').click()" style="background:#f9f9f9;border:1.5px dashed #ddd;border-radius:12px;padding:14px 10px;display:flex;flex-direction:column;align-items:center;gap:6px;cursor:pointer;font-family:'Inter',sans-serif;" onmouseenter="this.style.borderColor='#e00'" onmouseleave="this.style.borderColor='#ddd'">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#e00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>
      <span style="font-size:0.75rem;font-weight:700;color:#333;">Upload Photos</span>
    </button>
    <button onclick="toggleGateUrlInput()" style="background:#f9f9f9;border:1.5px dashed #ddd;border-radius:12px;padding:14px 10px;display:flex;flex-direction:column;align-items:center;gap:6px;cursor:pointer;font-family:'Inter',sans-serif;" onmouseenter="this.style.borderColor='#e00'" onmouseleave="this.style.borderColor='#ddd'">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#e00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      <span style="font-size:0.75rem;font-weight:700;color:#333;">Paste URL</span>
    </button>
  </div>
  <div id="gateUrlInputWrap" style="display:none;margin-bottom:8px;">
    <div style="display:flex;gap:8px;">
      <input id="gateDirectUrl" placeholder="https://image-url.com/photo.jpg" style="flex:1;padding:10px 14px;border:1.5px solid #eee;border-radius:10px;font-size:0.8rem;font-family:'Inter',sans-serif;outline:none;color:#111;"/>
      <button onclick="applyGateUrl()" style="background:#e00;color:#fff;border:none;border-radius:10px;padding:10px 14px;cursor:pointer;font-size:0.8rem;font-weight:700;font-family:'Inter',sans-serif;">Add</button>
    </div>
  </div>
  <input type="file" id="gateAdImgInput" accept="image/*" multiple style="display:none" onchange="gateUploadMultiImg(this)"/>
  <div id="gateMultiImgGrid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(75px,1fr));gap:6px;margin-bottom:6px;"></div>
  
  
  
  
</div>
   <div id="gateImgStatus" style="font-size:0.75rem;color:#6366f1;display:none;margin-bottom:4px;">Uploading...</div>
        <input type="hidden" id="gateAdImgUrl"/>
      </div>

      <div id="gateFormError" style="font-size:0.75rem;color:#e00;margin-bottom:10px;display:none;"></div>
      <button onclick="gateSubmitAd()" style="width:100%;padding:15px;background:#000;color:#fff;border:none;border-radius:14px;font-size:0.88rem;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;letter-spacing:0.3px;">
        Submit Ad Application →
      </button>
    </div>
  </div>
</div>

