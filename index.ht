  <!-- ════════ MAIL FILTER PANEL ════════ -->
  <!-- Trigger button — add this inside .topbar-right div -->

  <!-- Panel overlay -->
  <div id="filterOverlay" onclick="closeFilter()" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:299;backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px);"></div>

  <!-- Panel -->
  <div id="filterPanel" style="display:none;position:fixed;inset:0;z-index:300;background:#f8f9fa;overflow-y:auto;animation:slideUp 0.35s cubic-bezier(0.34,1.56,0.64,1);">
    
    <!-- Panel Header -->
    <div style="background:#000;color:#fff;padding:0 20px;height:60px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:10;border-bottom:1px solid #222;">
      <div style="display:flex;align-items:center;gap:12px;">
        <div style="width:32px;height:32px;background:#fff;border-radius:8px;display:flex;align-items:center;justify-content:center;">
          <!-- Gmail icon -->
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
            <path d="M2 6L12 13L22 6V4L12 11L2 4V6Z" fill="#EA4335"/>
            <path d="M2 6L2 18C2 19.1 2.9 20 4 20H9V13L2 6Z" fill="#34A853"/>
            <path d="M22 6V18C22 19.1 21.1 20 20 20H15V13L22 6Z" fill="#4285F4"/>
            <path d="M9 20H15V13L9 13V20Z" fill="#FBBC05"/>
          </svg>
        </div>
        <div>
          <div style="font-size:0.95rem;font-weight:700;display:flex;align-items:center;gap:7px;">
            Mail Filter
            <span style="font-size:0.65rem;background:#222;color:#888;padding:2px 6px;border-radius:4px;">v2.0</span>
          </div>
          <div style="font-size:0.7rem;color:#888;margin-top:1px;">Clean · Deduplicate · Export</div>
        </div>
      </div>
      <button onclick="closeFilter()" style="background:#1a1a1a;border:1px solid #333;color:#aaa;border-radius:8px;padding:8px 14px;cursor:pointer;font-size:0.82rem;font-weight:600;font-family:'Inter',sans-serif;display:flex;align-items:center;gap:6px;">
        <i data-lucide="x" style="width:13px;height:13px;"></i> Close
      </button>
    </div>

    <!-- Panel Body -->
    <div style="padding:20px 16px 60px;">

      <!-- Tips -->
      <div style="background:#fff;border:1px solid #e0e0e0;border-radius:10px;padding:12px 16px;display:flex;align-items:center;gap:10px;font-size:0.8rem;color:#5a5a5a;margin-bottom:20px;box-shadow:0 1px 4px rgba(0,0,0,0.06);">
        <i data-lucide="lightbulb" style="width:14px;height:14px;flex-shrink:0;"></i>
        Paste emails in any format — comma-separated, one per line, or mixed.
      </div>

      <!-- Stats -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:20px;">
        <div style="background:#fff;border:1px solid #e0e0e0;border-radius:10px;padding:16px;box-shadow:0 1px 4px rgba(0,0,0,0.06);">
          <div style="font-size:0.65rem;color:#8a8a8a;text-transform:uppercase;letter-spacing:0.06em;font-weight:600;margin-bottom:6px;display:flex;align-items:center;gap:5px;"><i data-lucide="inbox" style="width:11px;height:11px;"></i> Total Input</div>
          <div style="font-size:1.8rem;font-weight:800;letter-spacing:-0.03em;" id="fStatTotal">0</div>
        </div>
        <div style="background:#fff;border:1px solid #e0e0e0;border-radius:10px;padding:16px;box-shadow:0 1px 4px rgba(0,0,0,0.06);">
          <div style="font-size:0.65rem;color:#8a8a8a;text-transform:uppercase;letter-spacing:0.06em;font-weight:600;margin-bottom:6px;display:flex;align-items:center;gap:5px;"><i data-lucide="check-circle-2" style="width:11px;height:11px;"></i> Clean Unique</div>
          <div style="font-size:1.8rem;font-weight:800;letter-spacing:-0.03em;color:#1a6b3a;" id="fStatClean">0</div>
        </div>
        <div style="background:#fff;border:1px solid #e0e0e0;border-radius:10px;padding:16px;box-shadow:0 1px 4px rgba(0,0,0,0.06);">
          <div style="font-size:0.65rem;color:#8a8a8a;text-transform:uppercase;letter-spacing:0.06em;font-weight:600;margin-bottom:6px;display:flex;align-items:center;gap:5px;"><i data-lucide="copy-x" style="width:11px;height:11px;"></i> Duplicates</div>
          <div style="font-size:1.8rem;font-weight:800;letter-spacing:-0.03em;color:#c0392b;" id="fStatDupes">0</div>
        </div>
        <div style="background:#fff;border:1px solid #e0e0e0;border-radius:10px;padding:16px;box-shadow:0 1px 4px rgba(0,0,0,0.06);">
          <div style="font-size:0.65rem;color:#8a8a8a;text-transform:uppercase;letter-spacing:0.06em;font-weight:600;margin-bottom:6px;display:flex;align-items:center;gap:5px;"><i data-lucide="alert-triangle" style="width:11px;height:11px;"></i> Invalid</div>
          <div style="font-size:1.8rem;font-weight:800;letter-spacing:-0.03em;" id="fStatInvalid">0</div>
        </div>
      </div>

      <!-- Input Card -->
      <div style="background:#fff;border:1px solid #e0e0e0;border-radius:10px;overflow:hidden;margin-bottom:16px;box-shadow:0 1px 4px rgba(0,0,0,0.06);">
        <div style="padding:14px 16px;border-bottom:1px solid #e0e0e0;display:flex;align-items:center;justify-content:space-between;">
          <div style="font-weight:700;font-size:0.88rem;display:flex;align-items:center;gap:8px;"><i data-lucide="file-text" style="width:14px;height:14px;color:#5a5a5a;"></i> Raw Email List</div>
          <span style="background:#f1f3f5;border:1px solid #e0e0e0;border-radius:20px;font-size:0.72rem;font-weight:700;padding:3px 9px;display:flex;align-items:center;gap:4px;"><i data-lucide="hash" style="width:10px;height:10px;"></i><span id="fInputCount">0</span></span>
        </div>
        <textarea id="fInputEmails" oninput="fUpdateCount()" spellcheck="false" style="width:100%;min-height:180px;padding:14px 16px;font-family:'Courier New',monospace;font-size:0.8rem;line-height:1.7;background:#fff;color:#0a0a0a;border:none;outline:none;resize:vertical;" placeholder="Paste emails here...&#10;email1@example.com,&#10;email2@example.com"></textarea>
        <div style="padding:12px 16px;border-top:1px solid #e0e0e0;background:#f8f9fa;display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
          <button onclick="fFilter()" style="background:#000;color:#fff;border:none;border-radius:8px;padding:9px 18px;font-size:0.85rem;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;display:flex;align-items:center;gap:7px;"><i data-lucide="filter" style="width:13px;height:13px;"></i> Filter & Clean</button>
          <button onclick="fSave()" style="background:#fff;color:#374151;border:1.5px solid #d1d5db;border-radius:8px;padding:8px 14px;font-size:0.82rem;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;display:flex;align-items:center;gap:6px;"><i data-lucide="save" style="width:12px;height:12px;"></i> Save</button>
          <button onclick="fLoad()" style="background:#fff;color:#374151;border:1.5px solid #d1d5db;border-radius:8px;padding:8px 14px;font-size:0.82rem;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;display:flex;align-items:center;gap:6px;"><i data-lucide="folder-open" style="width:12px;height:12px;"></i> Load</button>
          <button onclick="fClearInput()" style="background:#fff;color:#c0392b;border:1.5px solid #e8c0bc;border-radius:8px;padding:8px 14px;font-size:0.82rem;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;display:flex;align-items:center;gap:6px;"><i data-lucide="trash-2" style="width:12px;height:12px;"></i> Clear</button>
        </div>
      </div>

      <!-- Output Card -->
      <div style="background:#fff;border:1px solid #e0e0e0;border-radius:10px;overflow:hidden;margin-bottom:16px;box-shadow:0 1px 4px rgba(0,0,0,0.06);">
        <div style="padding:14px 16px;border-bottom:1px solid #e0e0e0;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;">
          <div style="font-weight:700;font-size:0.88rem;display:flex;align-items:center;gap:8px;"><i data-lucide="list-checks" style="width:14px;height:14px;color:#5a5a5a;"></i> Cleaned List</div>
          <span style="background:#0a0a0a;color:#fff;border-radius:20px;font-size:0.72rem;font-weight:700;padding:3px 10px;display:flex;align-items:center;gap:5px;"><i data-lucide="check-circle" style="width:10px;height:10px;"></i><span id="fOutputCount">0</span> unique</span>
        </div>
        
        <div style="padding:12px 16px;border-bottom:1px solid #e0e0e0;background:#f8f9fa;display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
          <button onclick="fCopyAll()" style="background:#000;color:#fff;border:none;border-radius:8px;padding:9px 16px;font-size:0.82rem;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;display:flex;align-items:center;gap:7px;"><i data-lucide="clipboard-copy" style="width:12px;height:12px;"></i> Copy All</button>
          <button onclick="fDownloadTxt()" style="background:#fff;color:#374151;border:1.5px solid #d1d5db;border-radius:8px;padding:8px 14px;font-size:0.82rem;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;display:flex;align-items:center;gap:6px;"><i data-lucide="download" style="width:12px;height:12px;"></i> .txt</button>
          <button onclick="fDownloadCsv()" style="background:#fff;color:#374151;border:1.5px solid #d1d5db;border-radius:8px;padding:8px 14px;font-size:0.82rem;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;display:flex;align-items:center;gap:6px;"><i data-lucide="file-spreadsheet" style="width:12px;height:12px;"></i> .csv</button>
          <button onclick="fClearOutput()" style="background:#fff;color:#5a5a5a;border:1.5px solid #e0e0e0;border-radius:8px;padding:8px 14px;font-size:0.82rem;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;display:flex;align-items:center;gap:6px;"><i data-lucide="eraser" style="width:12px;height:12px;"></i> Clear</button>
        </div>
        <div id="fOutput" style="min-height:180px;max-height:400px;overflow-y:auto;padding:14px 16px;font-family:'Courier New',monospace;font-size:0.8rem;line-height:1.85;background:#fff;color:#bbb;font-style:italic;white-space:pre-wrap;word-break:break-all;cursor:default;user-select:all;">Filtered emails will appear here...</div>
        
      </div>

      <!-- Duplicates Card -->
      <div style="background:#fff;border:1px solid #e0e0e0;border-radius:10px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,0.06);">
        <div style="padding:14px 16px;border-bottom:1px solid #e0e0e0;display:flex;align-items:center;justify-content:space-between;">
          <div style="font-weight:700;font-size:0.88rem;display:flex;align-items:center;gap:8px;"><i data-lucide="layers" style="width:14px;height:14px;color:#5a5a5a;"></i> Duplicate Addresses</div>
          <div style="display:flex;align-items:center;gap:6px;">
            <span style="background:#f1f3f5;border:1px solid #e0e0e0;border-radius:20px;font-size:0.72rem;font-weight:700;padding:3px 9px;display:flex;align-items:center;gap:4px;" id="fDupeBadge"><i data-lucide="x-circle" style="width:10px;height:10px;"></i> 0 found</span>
            <button id="fToggleDupBtn" onclick="fToggleDupes()" style="display:none;background:#fff;color:#374151;border:1.5px solid #d1d5db;border-radius:6px;padding:6px 12px;font-size:0.78rem;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;display:none;align-items:center;gap:5px;"><i data-lucide="chevron-down" id="fDupChevron" style="width:12px;height:12px;"></i> <span id="fDupBtnText">Show</span></button>
          </div>
        </div>
        <div id="fDupWrap" style="max-height:0;overflow:hidden;transition:max-height 0.3s ease;">
          <div id="fDupList" style="padding:14px 16px;background:#f8f9fa;border-top:1px solid #e0e0e0;"></div>
        </div>
        <div id="fDupEmpty" style="padding:36px 20px;text-align:center;color:#bbb;font-size:0.82rem;display:flex;flex-direction:column;align-items:center;gap:8px;">
          <i data-lucide="inbox" style="width:32px;height:32px;color:#d0d0d0;"></i>
          No duplicates found yet — run a filter first
        </div>
      </div>

    </div>
  </div>

</div><!-- end app -->

<script>
function i(){ if(typeof lucide!=='undefined') lucide.createIcons(); }


