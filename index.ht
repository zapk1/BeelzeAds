</button>
    <div id="gateLogoTitle" style="font-size:1.5rem;font-weight:900;letter-spacing:-1px;color:#000;cursor:pointer;display:inline-block;" ondblclick="openAdminGate()">BeelzeAds</div>

<!-- ADMIN LOGIN MODAL -->
<div id="adminGateOverlay" onclick="closeAdminGate()" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:999;backdrop-filter:blur(8px);"></div>
<div id="adminGateModal" style="display:none;position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:1000;width:min(340px,90vw);background:#000;border-radius:24px;padding:36px 28px;box-shadow:0 30px 80px rgba(0,0,0,0.5);border:1px solid #222;">
  <div style="text-align:center;margin-bottom:28px;">
