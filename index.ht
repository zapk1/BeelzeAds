/* ─── EMAILS ─── */
let emails = [];
function addEmails(){
  const raw = document.getElementById('emailInput').value;
  const parts = raw.split(/[\n,;]+/).map(e=>e.trim()).filter(e=>e.includes('@'));
  parts.forEach(e=>{ if(!emails.includes(e)) emails.push(e); });
  document.getElementById('emailInput').value = '';
  renderEmails();
  updateStats();
  saveToLS();
}
document.getElementById('emailInput').addEventListener('keydown', e=>{
  if(e.key==='Enter'){ e.preventDefault(); addEmails(); }
});
function removeEmail(idx){ emails.splice(idx,1); renderEmails(); updateStats(); saveToLS(); }
function renderEmails(){
  const el = document.getElementById('emailList');
  if(!emails.length){ el.innerHTML='<div class="list-empty">No emails added yet</div>'; }
  else {
    el.innerHTML = emails.map((e,idx)=>`
      <div class="list-item">
        <div style="display:flex;align-items:center;gap:9px">
          <div style="width:28px;height:28px;border-radius:50%;background:#ede9fe;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;color:#6366f1;flex-shrink:0">${e[0].toUpperCase()}</div>
          <span>${e}</span>
        </div>
        <button class="rm" onclick="removeEmail(${idx})"><i data-lucide="x" style="width:13px;height:13px"></i></button>
      </div>`).join('');
  }
  const rb = document.getElementById('recipientBadge');
  const cb = document.getElementById('countBadge');
  if(rb) rb.textContent = emails.length + ' emails';
  if(cb) cb.textContent = emails.length + ' emails';
  i();
}

/* ─── SENDER ACCOUNTS ─── */
let senderAccounts = [];


function addAccount(){
  const raw = document.getElementById('accountInput').value;
  // Split by newlines OR commas
  const lines = raw.split(/[\n,]+/).map(l=>l.trim()).filter(l=>l.length>0);
  lines.forEach(line => {
    // Try "email - password" (with spaces) first, then "email-password" (no spaces)
    let email = '', password = '';
    const spaceMatch = line.match(/^([^\s]+@[^\s]+)\s*[-–]\s*(.+)$/);
    if(spaceMatch){
      email = spaceMatch[1].trim();
      password = spaceMatch[2].trim();
    } else {
      // No spaces: find last @ then split at next dash after domain
      const atIdx = line.lastIndexOf('@');
      if(atIdx === -1) return;
      const afterAt = line.indexOf('-', atIdx);
      if(afterAt === -1) return;
      email = line.substring(0, afterAt).trim();
      password = line.substring(afterAt + 1).trim();
    }
    if(email.includes('@') && password && !senderAccounts.find(a=>a.email===email))
      senderAccounts.push({email, password});
  });
  document.getElementById('accountInput').value='';
  renderAccounts(); updateStats(); saveToLS();
}





function removeAccount(idx){ senderAccounts.splice(idx,1); renderAccounts(); updateStats(); saveToLS(); }
function renderAccounts(){
  const el = document.getElementById('accountList');
  if(!senderAccounts.length){ el.innerHTML='<div class="list-empty">No accounts added</div>'; }
  else {
    el.innerHTML = senderAccounts.map((a,idx)=>`
      <div class="list-item">
        <div style="display:flex;align-items:center;gap:9px">
          <div style="width:28px;height:28px;border-radius:50%;background:#dcfce7;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;color:#16a34a;flex-shrink:0">${a.email[0].toUpperCase()}</div>
          <div><div style="font-weight:600;font-size:0.84rem">${a.email}</div><div style="font-size:0.7rem;color:var(--text3);letter-spacing:1px">${'•'.repeat(Math.min(a.password.length,12))}</div></div>
        </div>
        <button class="rm" onclick="removeAccount(${idx})"><i data-lucide="x" style="width:13px;height:13px"></i></button>
      </div>`).join('');
  }
  document.getElementById('accountBadge').textContent = senderAccounts.length;
  i();
}

/* ─── PROXIES ─── */
let proxies = [];
function parseProxies(){
  const raw = document.getElementById('proxyRaw').value;
  const lines = raw.split('\n').map(l=>l.trim()).filter(l=>l.length>0);
  proxies = [];
  lines.forEach(line => {
    const ipM   = line.match(/IP:\s*([\d.]+)/i);
    const portM = line.match(/PORT:\s*(\d+)/i);
    const userM = line.match(/USERNAME:\s*(\S+)/i);
    const passM = line.match(/PASSWORD:\s*(\S+)/i);
    if(ipM && portM){
      proxies.push({ ip:ipM[1], port:portM[1], user:userM?userM[1]:'', pass:passM?passM[1]:'' });
      return;
    }
    const p = line.split(':');
    if(p.length>=2 && p[0].match(/^\d+\.\d+/))
      proxies.push({ ip:p[0], port:p[1], user:p[2]||'', pass:p[3]||'' });
  });
  const hint = document.getElementById('proxyHint');
  hint.innerHTML = proxies.length > 0
    ? `<i data-lucide="check-circle" style="width:11px;height:11px;color:#16a34a"></i> <span style="color:#16a34a">${proxies.length} proxies parsed</span>`
    : `<i data-lucide="info" style="width:11px;height:11px"></i> Proxies parsed automatically as you type`;
  document.getElementById('proxyBadge').textContent = proxies.length;
  updateStats(); i();
}

/* ─── DOMAINS ─── */
let domains = [];
function addDomain(){
  const text = document.getElementById('dText').value.trim();
  const url  = document.getElementById('dUrl').value.trim();
  if(!url) return;
  domains.push({ text: text||url, url });
  document.getElementById('dText').value='';
  document.getElementById('dUrl').value='';
  renderDomains(); saveToLS();
}
function removeDomain(idx){ domains.splice(idx,1); renderDomains(); saveToLS(); }
function renderDomains(){
  document.getElementById('domainList').innerHTML = domains.map((d,idx)=>`
    <div class="domain-chip">
      <a href="${d.url}" target="_blank">${d.text} — ${d.url}</a>
      <button onclick="removeDomain(${idx})"><i data-lucide="x" style="width:13px;height:13px"></i></button>
    </div>`).join('');
  i();
}

/* ─── IMAGES ─── */
let uploadedImages = [];
const IMGBB_KEY = '7582cc8e40651016b8391c34b4216727';

function addDirectUrl(){
  const url=document.getElementById('directImgUrl').value.trim(); if(!url) return;
  const idx=uploadedImages.length; uploadedImages.push({name:url,url});
  addImgCard(url,url,idx);
  document.getElementById('directImgUrl').value='';
  document.getElementById('urlInputWrap').style.display='none';
}
async function uploadImages(files){
  const status = document.getElementById('uploadStatus');
  for(const file of files){
    const idx = uploadedImages.length;
    uploadedImages.push(null);
    status.innerHTML = `<div style="margin-bottom:8px;"><div style="font-size:0.78rem;color:#555;margin-bottom:5px;">Uploading <strong>${file.name}</strong>...</div><div style="background:#e5e7eb;border-radius:99px;height:6px;overflow:hidden;"><div id="uploadBar" style="height:100%;width:0%;background:linear-gradient(90deg,#6366f1,#8b5cf6);border-radius:99px;transition:width 0.3s;"></div></div></div>`;
    let prog=0;
    const barTimer=setInterval(()=>{ prog=Math.min(prog+Math.random()*18,85); const b=document.getElementById('uploadBar'); if(b) b.style.width=prog+'%'; },200);
    const form=new FormData(); form.append('image',file);
    const res=await fetch(`https://api.imgbb.com/1/upload?key=${IMGBB_KEY}`,{method:'POST',body:form});
    const data=await res.json();
    clearInterval(barTimer);
    const b=document.getElementById('uploadBar'); if(b) b.style.width='100%';
    if(data.success){
      const url=data.data.url;
      uploadedImages[idx]={name:file.name,url};
      setTimeout(()=>{ status.innerHTML=`<div style="font-size:0.78rem;color:#16a34a;margin-bottom:8px;">✓ ${file.name} uploaded!</div>`; addImgCard(url,file.name,idx); },300);
    } else {
      status.innerHTML=`<div style="font-size:0.78rem;color:#ef4444;margin-bottom:8px;">✕ Upload failed</div>`;
    }
  }
  document.getElementById('imgInput').value='';
}


function addImgCard(url,name,idx){
  const grid=document.getElementById('imgGrid'); const div=document.createElement('div');
  div.className='img-card'; div.id='imgcard_'+idx;
  div.innerHTML=`<button class="rm-btn" onclick="removeImg(${idx})" style="position:absolute;top:5px;right:5px;background:rgba(0,0,0,0.6);border:none;border-radius:50%;width:24px;height:24px;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:2;"><i data-lucide="x" style="width:12px;height:12px"></i></button><img src="${url}" alt="${name}" style="width:100%;height:80px;object-fit:cover;display:block;border-radius:10px 10px 0 0;"/><div style="padding:5px 7px;font-size:0.65rem;color:#666;word-break:break-all;">${name.length>22?name.substring(0,22)+'…':name}</div>`;
  grid.appendChild(div); i();
}
function removeImg(idx){ uploadedImages[idx]=null; const el=document.getElementById('imgcard_'+idx); if(el) el.remove(); }

/* ─── STATS ─── */
function updateStats(){
  document.getElementById('statSent').textContent       = sessionSent;
  document.getElementById('statRecipients').textContent = emails.length;
  document.getElementById('statProxies').textContent    = proxies.length;
  document.getElementById('statAccounts').textContent   = senderAccounts.length;
}
let sessionSent = 0;

/* ─── LOCALSTORAGE PERSISTENCE ─── */
function saveToLS() {
  localStorage.setItem('beelze_emails',   JSON.stringify(emails));
  localStorage.setItem('beelze_accounts', JSON.stringify(senderAccounts));
  localStorage.setItem('beelze_proxies',  JSON.stringify(proxies));
  localStorage.setItem('beelze_proxyRaw', document.getElementById('proxyRaw').value);
  localStorage.setItem('beelze_domains',  JSON.stringify(domains));
  localStorage.setItem('beelze_images',   JSON.stringify(uploadedImages.filter(Boolean)));
  localStorage.setItem('beelze_subject',  document.getElementById('cSubject').value);
  localStorage.setItem('beelze_body',     document.getElementById('cBody').value);
  localStorage.setItem('beelze_sender',   document.getElementById('cSenderName').value);
  localStorage.setItem('beelze_smtpHost', document.getElementById('smtpHost').value);
  localStorage.setItem('beelze_smtpPort', document.getElementById('smtpPort').value);
}

function loadFromLS() {
  emails          = JSON.parse(localStorage.getItem('beelze_emails')   || '[]');
  senderAccounts  = JSON.parse(localStorage.getItem('beelze_accounts') || '[]');
  proxies         = JSON.parse(localStorage.getItem('beelze_proxies')  || '[]');
  domains         = JSON.parse(localStorage.getItem('beelze_domains')  || '[]');
  uploadedImages  = JSON.parse(localStorage.getItem('beelze_images')   || '[]');

  const proxyRaw  = localStorage.getItem('beelze_proxyRaw');
  if (proxyRaw)  document.getElementById('proxyRaw').value      = proxyRaw;
  const subject   = localStorage.getItem('beelze_subject');
  if (subject)   document.getElementById('cSubject').value      = subject;
  const body      = localStorage.getItem('beelze_body');
  if (body)      document.getElementById('cBody').value         = body;
  const sender    = localStorage.getItem('beelze_sender');
  if (sender)    document.getElementById('cSenderName').value   = sender;
  const smtpHost  = localStorage.getItem('beelze_smtpHost');
  if (smtpHost)  document.getElementById('smtpHost').value      = smtpHost;
  const smtpPort  = localStorage.getItem('beelze_smtpPort');
  if (smtpPort)  document.getElementById('smtpPort').value      = smtpPort;

  renderEmails(); renderAccounts(); renderDomains(); updateStats();

  // Re-render images
  uploadedImages.forEach((img, idx) => { if(img) addImgCard(img.url, img.name, idx); });

  // Proxy count badge
  document.getElementById('proxyBadge').textContent = proxies.length;
}



/* ─── ADS ─── */
function toggleAd(el, placement){
  console.log('Ad placement toggled:', placement, el.checked ? 'ON' : 'OFF');
}
function copySnippet(){
  const code = document.getElementById('adSnippet').textContent;
  navigator.clipboard.writeText(code);
  const btn = event.target.closest('.copy-btn');
  btn.classList.add('copied'); btn.innerHTML='<i data-lucide="check" style="width:12px;height:12px"></i> Copied!'; i();
  setTimeout(()=>{ btn.classList.remove('copied'); btn.innerHTML='<i data-lucide="copy" style="width:12px;height:12px"></i> Copy'; i(); },2500);
}
function openColab(){ window.open('https://colab.research.google.com','_blank'); }

/* ─── GENERATE PYTHON ─── */
function generate(){
  const smtpHost     = document.getElementById('smtpHost').value.trim();
  const smtpPort     = document.getElementById('smtpPort').value.trim();
  const senderEmail  = senderAccounts.length > 0 ? senderAccounts[0].email : 'sender@gmail.com';
  const subject      = document.getElementById('cSubject').value.trim() || 'Hello from BeelzeAds';
  const batchSize    = document.getElementById('cBatchSize').value.trim() || '50';
  const emailsPerAcc = document.getElementById('cEmailsPerAcc').value.trim() || '100';
  const bodyMsg      = document.getElementById('cBody').value.trim() || 'Hello {name},\n\nYour message here.';
  const senderNameV  = document.getElementById('cSenderName').value.trim() || 'BeelzeAds';
  const proxyType    = document.getElementById('proxyType').value;

  const allAccounts = senderAccounts.length > 0 ? senderAccounts : [{ email: senderEmail, password: '(your-app-password-here)' }];

  const imgHtml    = uploadedImages.filter(Boolean).map(img=>`  <img src="${img.url}" alt="image" style="max-width:100%;margin:10px 0;border-radius:10px;"/>`).join('\n');
  const domainHtml = domains.map(d=>`  <p style="margin:8px 0;"><a href="${d.url}" target="_blank" style="color:#6366f1;font-weight:700;text-decoration:none;">${d.text}</a></p>`).join('\n');
  const bodyLines  = bodyMsg.split('\n').map(l=>`  <p style="margin:4px 0;">${l}</p>`).join('\n');
  const htmlBody   = `<html><body style="font-family:Arial,sans-serif;color:#111;max-width:600px;margin:0 auto;padding:20px;">\n${bodyLines}\n${imgHtml}\n${domainHtml}\n  <p style="margin-top:20px;color:#555;">Best regards,<br/><strong>${senderNameV}</strong></p>\n</body></html>`;
  const textBody   = bodyMsg + `\n\nBest regards,\n${senderNameV}`;

  const accountsPy  = allAccounts.map(a=>`    {"email": "${a.email}", "password": "${a.password}"},`).join('\n');
  const proxiesPy   = proxies.length > 0
    ? proxies.map(p=>`    {"ip": "${p.ip}", "port": ${p.port}, "user": "${p.user}", "pass": "${p.pass}"},`).join('\n')
    : '    # No proxies — running direct SMTP';
  const recipientsPy = emails.map(e=>`    {"email": "${e}", "name": "Friend"},`).join('\n');
  const useProxy    = proxies.length > 0 ? 'True' : 'False';

  const code = `#!/usr/bin/env python3
"""
╔══════════════════════════════════════════════════════════╗
║           BeelzeAds — Pro Mail Campaign Engine           ║
║    Proxy IP Rotation + Account Rotation + BCC Blast      ║
║                  Powered by BeelzeAds v2                 ║
╚══════════════════════════════════════════════════════════╝

FEATURES:
  ✅ IP rotates on every email (individual mode) or every batch (BCC)
  ✅ Account switch delay: random 20–50 seconds
  ✅ BCC batch delay:      random 40–120 seconds
  ✅ Per-email delay:      random 5–15 seconds
  ✅ SOCKS5/SOCKS4/HTTP proxy support

REQUIREMENTS:
  pip install PySocks

HOW TO RUN:
  1. Copy this script
  2. Open https://colab.research.google.com
  3. New Notebook → Paste → Run first cell: !pip install PySocks
  4. Run second cell with this script
"""

import smtplib, ssl, time, random, datetime
from email.mime.multipart import MIMEMultipart
from email.mime.text import MIMEText
${proxies.length > 0 ? 'import socks' : '# PySocks not needed — no proxies configured'}

# ══════════════════════════════════════════
#                  CONFIG
# ══════════════════════════════════════════
SMTP_HOST       = "${smtpHost}"
SMTP_PORT       = ${smtpPort}
SUBJECT         = "${subject}"
SEND_MODE       = "${sendMode}"       # "bcc" or "individual"
BATCH_SIZE      = ${batchSize}        # emails per BCC batch
EMAILS_PER_ACCT = ${emailsPerAcc}     # before switching sender
PROXY_TYPE_STR  = "${proxyType}"      # socks5 / socks4 / http
USE_PROXY       = ${useProxy}

# Email body
BODY_HTML = """${htmlBody.replace(/\\/g, '\\\\').replace(/"""/g, "'''")}"""

BODY_TEXT = """${textBody.replace(/\\/g, '\\\\').replace(/"""/g, "'''")}"""

# Sender accounts — format: {email, password}
ACCOUNTS = [
${accountsPy}
]

# Proxy list — leave empty to send direct
PROXIES = [
${proxiesPy}
]

# Recipients
RECIPIENTS = [
${recipientsPy || '    # Add recipients above'}
]

# ══════════════════════════════════════════
#               PROXY SETUP
# ══════════════════════════════════════════
${proxies.length > 0 ? `PROXY_MAP = {
    "socks5": socks.SOCKS5,
    "socks4": socks.SOCKS4,
    "http":   socks.HTTP,
}` : ''}

def ts():
    return datetime.datetime.now().strftime("%H:%M:%S")

def get_proxy(idx):
    if not USE_PROXY or not PROXIES:
        return None
    return PROXIES[idx % len(PROXIES)]

${proxies.length > 0 ? `def smtp_via_proxy(proxy, sender_email, sender_pass):
    """Connect SMTP through a SOCKS/HTTP proxy."""
    sock = socks.socksocket()
    sock.set_proxy(
        PROXY_MAP.get(PROXY_TYPE_STR, socks.SOCKS5),
        proxy["ip"],
        int(proxy["port"]),
        True,
        proxy["user"] if proxy["user"] else None,
        proxy["pass"] if proxy["pass"] else None,
    )
    sock.connect((SMTP_HOST, SMTP_PORT))
    # Wrap socket into SMTP
    conn = smtplib.SMTP.__new__(smtplib.SMTP)
    conn.sock = sock
    conn.file = sock.makefile("rb")
    conn._tls_required = False
    conn.ehlo_resp = None
    conn.does_esmtp = False
    conn.default_port = SMTP_PORT
    conn.timeout = 30
    conn.getreply()
    conn.ehlo()
    ctx = ssl.create_default_context()
    conn.starttls(context=ctx)
    conn.ehlo()
    conn.login(sender_email, sender_pass)
    return conn` : ''}

def smtp_direct(sender_email, sender_pass):
    """Connect SMTP directly (no proxy)."""
    ctx = ssl.create_default_context()
    conn = smtplib.SMTP(SMTP_HOST, SMTP_PORT)
    conn.starttls(context=ctx)
    conn.login(sender_email, sender_pass)
    return conn

def get_smtp(proxy, sender_email, sender_pass):
    if USE_PROXY and proxy:
        print(f"  [PROXY] {proxy['ip']}:{proxy['port']} ({PROXY_TYPE_STR.upper()})")
        ${proxies.length > 0 ? 'return smtp_via_proxy(proxy, sender_email, sender_pass)' : 'return smtp_direct(sender_email, sender_pass)'}
    return smtp_direct(sender_email, sender_pass)

# ══════════════════════════════════════════
#            EMAIL BUILDERS
# ══════════════════════════════════════════
def build_bcc(sender_email):
    msg = MIMEMultipart("alternative")
    msg["From"]    = sender_email
    msg["To"]      = sender_email
    msg["Subject"] = SUBJECT
    msg.attach(MIMEText(BODY_TEXT.replace("{name}", "Friend"), "plain"))
    msg.attach(MIMEText(BODY_HTML.replace("{name}", "Friend"), "html"))
    return msg

def build_individual(sender_email, recipient):
    msg = MIMEMultipart("alternative")
    msg["From"]    = sender_email
    msg["To"]      = recipient["email"]
    msg["Subject"] = SUBJECT
    name = recipient.get("name", "Friend")
    msg.attach(MIMEText(BODY_TEXT.format(name=name), "plain"))
    msg.attach(MIMEText(BODY_HTML.format(name=name), "html"))
    return msg

# ══════════════════════════════════════════
#               MAIN ENGINE
# ══════════════════════════════════════════
def run():
    queue        = list(RECIPIENTS)
    total        = len(queue)
    sent         = 0
    failed       = 0
    proxy_idx    = 0

    print("")
    print("╔══════════════════════════════════════════════════════════╗")
    print("║             BeelzeAds — Campaign Starting                ║")
    print("╚══════════════════════════════════════════════════════════╝")
    print(f"  Time        : {datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print(f"  Recipients  : {total}")
    print(f"  Accounts    : {len(ACCOUNTS)}")
    print(f"  Proxies     : {len(PROXIES)}")
    print(f"  Mode        : {SEND_MODE.upper()}")
    print(f"  Batch Size  : {BATCH_SIZE}")
    print(f"  Subject     : {SUBJECT}")
    print("─" * 60)

    for acc_idx, account in enumerate(ACCOUNTS):
        if not queue:
            print("\\n  ✅ All recipients covered!")
            break

        batch      = queue[:EMAILS_PER_ACCT]
        queue      = queue[EMAILS_PER_ACCT:]
        acc_email  = account["email"]
        acc_pass   = account["password"]

        print(f"\\n▶ Account {acc_idx+1}/{len(ACCOUNTS)}: {acc_email}")
        print(f"  Sending to: {len(batch)} recipients")

        sub_batches = [batch[i:i+BATCH_SIZE] for i in range(0, len(batch), BATCH_SIZE)]

        for sb_idx, sub in enumerate(sub_batches):
            proxy = get_proxy(proxy_idx)
            proxy_idx += 1

            proxy_label = f"{proxy['ip']}:{proxy['port']}" if proxy else "Direct"
            print(f"\\n  ┌ Sub-batch {sb_idx+1}/{len(sub_batches)}")
            print(f"  │ Emails  : {len(sub)}")
            print(f"  │ Proxy   : {proxy_label}")
            print(f"  │ Time    : {ts()}")

            try:
                server = get_smtp(proxy, acc_email, acc_pass)
                print(f"  │ Login   : ✅ OK")

                if SEND_MODE == "bcc":
                    try:
                        msg    = build_bcc(acc_email)
                        all_to = [acc_email] + [r["email"] for r in sub]
                        server.sendmail(acc_email, all_to, msg.as_string())
                        sent  += len(sub)
                        print(f"  └ ✅ BCC sent {len(sub)} | Total: {sent}/{total}")
                    except Exception as e:
                        failed += len(sub)
                        print(f"  └ ❌ BCC Failed: {e}")
                else:
                    for i_idx, r in enumerate(sub, 1):
                        # Rotate proxy every email in individual mode
                        if i_idx > 1:
                            proxy = get_proxy(proxy_idx)
                            proxy_idx += 1
                            try:
                                server.quit()
                            except: pass
                            try:
                                server = get_smtp(proxy, acc_email, acc_pass)
                            except Exception as e:
                                print(f"    [PROXY FAIL] {e}")
                                continue
                        try:
                            msg = build_individual(acc_email, r)
                            server.sendmail(acc_email, [r["email"]], msg.as_string())
                            sent += 1
                            proxy_label = f"{proxy['ip']}" if proxy else "Direct"
                            print(f"  │ [{i_idx}/{len(sub)}] ✅ {r['email']} via {proxy_label} | Total: {sent}")
                        except Exception as e:
                            failed += 1
                            print(f"  │ [{i_idx}/{len(sub)}] ❌ {r['email']} | {e}")
                        # Per-email delay
                        if i_idx < len(sub):
                            d = random.randint(5, 15)
                            print(f"  │ ⏱  Next in {d}s…")
                            time.sleep(d)
                    print(f"  └ Sub-batch done")

                try: server.quit()
                except: pass

            except Exception as e:
                print(f"  └ ❌ Connection failed: {e}")

            # BCC batch delay: random 40–120s
            if sb_idx < len(sub_batches) - 1:
                d = random.randint(40, 120)
                print(f"\\n  ⏳ Next batch in {d}s (IP rotating)…")
                time.sleep(d)

        # Account switch delay: random 20–50s
        if queue and acc_idx < len(ACCOUNTS) - 1:
            d = random.randint(20, 50)
            print(f"\\n  🔄 Switching account in {d}s…")
            time.sleep(d)

    print("\\n╔══════════════════════════════════════════════════════════╗")
    print(f"║  CAMPAIGN COMPLETE                                       ║")
    print(f"║  Sent: {str(sent).ljust(8)} Failed: {str(failed).ljust(8)} Total: {str(total).ljust(10)} ║")
    print(f"║  Finished: {datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')}                         ║")
    print("╚══════════════════════════════════════════════════════════╝")

if __name__ == "__main__":
    run()
`;

  document.getElementById('codeOutput').textContent = code;
  document.getElementById('outputSection').style.display = 'block';
  document.getElementById('outputSection').scrollIntoView({ behavior:'smooth' });
  sessionSent = emails.length;
  updateStats();
  i();
}

function copyCode(){
  const code = document.getElementById('codeOutput').textContent;
  navigator.clipboard.writeText(code);
  const btn = document.getElementById('copyBtn');
  btn.classList.add('copied'); btn.innerHTML='<i data-lucide="check" style="width:12px;height:12px"></i> Copied!'; i();
  setTimeout(()=>{ btn.classList.remove('copied'); btn.innerHTML='<i data-lucide="copy" style="width:12px;height:12px"></i> Copy'; i(); }, 2500);
}

// Auto-save compose fields as user types
['cSubject','cBody','cSenderName','smtpHost','smtpPort'].forEach(id => {
  const el = document.getElementById(id);
  if(el) el.addEventListener('input', saveToLS);
});

// ─── MAIL FILTER PANEL ───
let fCleanedList = [];
let fDupesOpen   = false;

function openFilter()  {
  document.getElementById('filterOverlay').style.display = 'block';
  document.getElementById('filterPanel').style.display   = 'block';
  document.body.style.overflow = 'hidden';
  i();
}
function closeFilter() {
  document.getElementById('filterOverlay').style.display = 'none';
  document.getElementById('filterPanel').style.display   = 'none';
  document.body.style.overflow = '';
}

function fUpdateCount() {
  const raw = document.getElementById('fInputEmails').value;
  const n   = raw.split(/[\n,]+/).map(e=>e.trim()).filter(e=>e.length>0).length;
  document.getElementById('fInputCount').textContent = n;
  i();
}

function fFilter() {
  const raw = document.getElementById('fInputEmails').value.trim();
  if(!raw) { fToast('Paste some emails first','alert-circle'); return; }
  const parts = raw.split(/[\n,]+/).map(e=>e.trim().toLowerCase()).filter(e=>e.length>0);
  let valid=[], invalid=0;
  parts.forEach(e=>{ /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(e) ? valid.push(e) : invalid++; });
  const total=parts.length, seen={}, unique=[], dupeMap={};
  let dupeCount=0;
  valid.forEach(e=>{ if(seen[e]){ seen[e]++; dupeMap[e]=seen[e]; dupeCount++; } else { seen[e]=1; unique.push(e); } });
  fCleanedList=unique;
  const out=document.getElementById('fOutput');
  if(unique.length>0){ out.style.color='#0a0a0a'; out.style.fontStyle='normal'; out.textContent=unique.map(e=>e+',').join('\n'); }
  else { out.style.color='#bbb'; out.style.fontStyle='italic'; out.textContent='No valid emails found.'; }
  document.getElementById('fOutputCount').textContent=unique.length;
  document.getElementById('fStatTotal').textContent=total;
  document.getElementById('fStatClean').textContent=unique.length;
  document.getElementById('fStatDupes').textContent=dupeCount;
  document.getElementById('fStatInvalid').textContent=invalid;
  fRenderDupes(dupeMap,dupeCount);
  fToast(`${unique.length} clean · ${dupeCount} dupes removed`,'check-circle-2');
  i();
}

function fRenderDupes(map,count) {
  const badge=document.getElementById('fDupeBadge');
  const empty=document.getElementById('fDupEmpty');
  const btn  =document.getElementById('fToggleDupBtn');
  const list =document.getElementById('fDupList');
  badge.innerHTML=`<i data-lucide="x-circle" style="width:10px;height:10px;"></i> ${count} found`;
  if(count===0){ empty.style.display='flex'; btn.style.display='none'; list.innerHTML=''; document.getElementById('fDupWrap').style.maxHeight='0'; i(); return; }
  empty.style.display='none'; btn.style.display='flex';
  const entries=Object.entries(map).sort((a,b)=>b[1]-a[1]);
  list.innerHTML=`<div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#8a8a8a;margin-bottom:10px;display:flex;align-items:center;gap:6px;"><i data-lucide="repeat" style="width:11px;height:11px;"></i>${entries.length} address${entries.length>1?'es':''} appeared more than once</div>`
    +entries.map(([email,count])=>`<div style="display:flex;align-items:center;gap:8px;padding:7px 10px;background:#fff;border:1px solid #e0e0e0;border-radius:6px;margin-bottom:5px;font-family:'Courier New',monospace;font-size:0.8rem;color:#5a5a5a;"><i data-lucide="alert-circle" style="width:12px;height:12px;color:#c0392b;flex-shrink:0;"></i>${email}<span style="margin-left:auto;background:#f1f3f5;border:1px solid #e0e0e0;border-radius:20px;font-size:0.7rem;font-weight:700;color:#5a5a5a;padding:2px 8px;">×${count+1}</span></div>`).join('');
  i();
}

function fToggleDupes() {
  fDupesOpen=!fDupesOpen;
  document.getElementById('fDupWrap').style.maxHeight=fDupesOpen?'400px':'0';
  document.getElementById('fDupBtnText').textContent=fDupesOpen?'Hide':'Show';
  document.getElementById('fDupChevron').setAttribute('data-lucide', fDupesOpen?'chevron-up':'chevron-down');
  i();
}

function fCopyAll() {
  if(!fCleanedList.length){ fToast('Nothing to copy — run filter first','alert-circle'); return; }
  navigator.clipboard.writeText(fCleanedList.map(e=>e+',').join('\n')).then(()=>fToast('Copied '+fCleanedList.length+' emails','clipboard-check'));
}

function fDownloadTxt() {
  if(!fCleanedList.length){ fToast('Nothing to download','alert-circle'); return; }
  fTriggerDl(fCleanedList.map(e=>e+',').join('\n'),'beelzeads_clean_emails.txt','text/plain');
  fToast('Downloaded .txt','download');
}

function fDownloadCsv() {
  if(!fCleanedList.length){ fToast('Nothing to download','alert-circle'); return; }
  fTriggerDl('email\n'+fCleanedList.join('\n'),'beelzeads_clean_emails.csv','text/csv');
  fToast('Downloaded .csv','download');
}

function fTriggerDl(content,filename,type) {
  const blob=new Blob([content],{type}); const a=document.createElement('a');
  a.href__=URL.createObjectURL(blob); a.download=filename; a.click(); URL.revokeObjectURL(a.href);
}

function fClearInput() {
  document.getElementById('fInputEmails').value='';
  document.getElementById('fInputCount').textContent='0';
  fToast('Input cleared','trash-2');
}

function fClearOutput() {
  fCleanedList=[];
  const out=document.getElementById('fOutput');
  out.style.color='#bbb'; out.style.fontStyle='italic';
  out.textContent='Filtered emails will appear here...';
  document.getElementById('fOutputCount').textContent='0';
  ['fStatTotal','fStatClean','fStatDupes','fStatInvalid'].forEach(id=>document.getElementById(id).textContent='0');
  fRenderDupes({},0);
  fToast('Output cleared','eraser');
}

function fSave() {
  const val=document.getElementById('fInputEmails').value;
  if(!val.trim()){ fToast('Nothing to save','alert-circle'); return; }
  localStorage.setItem('beelzeads_input',val);
  fToast('Saved to browser storage','save');
}

function fLoad() {
  const val=localStorage.getItem('beelzeads_input');
  if(val){ document.getElementById('fInputEmails').value=val; fUpdateCount(); fToast('Loaded from storage','folder-open'); }
  else { fToast('No saved data found','alert-circle'); }
}

function fToast(msg,icon='check-circle') {
  // Re-use the existing showToast if available in same scope
  // otherwise use simple alert fallback
  if(typeof showToast==='function') { showToast(msg,icon); }
}

// Add slide-up animation
const filterStyle=document.createElement('style');
filterStyle.textContent='@keyframes slideUp{from{transform:translateY(100%);opacity:0}to{transform:translateY(0);opacity:1}}';
document.head.appendChild(filterStyle);

/* ─── BeelzeAds animated title ─── */
const BEELZE_LETTERS = ['B','e','e','l','z','e','A','d','s'];
let beelzeTimer = null;

function startBeelzeAnim() {
  const el = document.getElementById('pageTitle');
  el.style.fontVariantNumeric = 'tabular-nums';
  let step = 0;

  function tick() {
    // Show letters one block at a time, cycling
    const shown = BEELZE_LETTERS.slice(0, (step % (BEELZE_LETTERS.length + 3)) + 1);
    if (shown.length > BEELZE_LETTERS.length) {
      // Full word — fade hold then reset
      el.style.opacity = '1';
      el.textContent = 'BeelzeAds';
      step = 0;
    } else {
      el.style.opacity = String(0.4 + (shown.length / BEELZE_LETTERS.length) * 0.6);
      el.textContent = shown.join('');
    }
    step++;
    beelzeTimer = setTimeout(tick, step % (BEELZE_LETTERS.length + 3) === 0 ? 3000 : 320);
  }

  stopBeelzeAnim();
  tick();
}

function stopBeelzeAnim() {
  if (beelzeTimer) { clearTimeout(beelzeTimer); beelzeTimer = null; }
  document.getElementById('pageTitle').style.opacity = '1';
}

// Start anim on load since dashboard is default
startBeelzeAnim();

function toggleImgPanel() {
  const panel   = document.getElementById('imgPanel');
  const chevron = document.getElementById('imgChevron');
  const open    = panel.style.display === 'block';
  panel.style.display   = open ? 'none' : 'block';
  chevron.style.transform = open ? 'rotate(0deg)' : 'rotate(180deg)';
  i();
}

function toggleUrlInput() {
  const wrap = document.getElementById('urlInputWrap');
  wrap.style.display = wrap.style.display === 'block' ? 'none' : 'block';
  i();
}

// Init icons after everything loads
setTimeout(i, 100);

</script>
</body>
</html>
