      <div style="display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:4px">
        <div style="width:24px;height:24px;background:linear-gradient(135deg,#6366f1,#8b5cf6);border-radius:8px;display:flex;align-items:center;justify-content:center">
          <i data-lucide="zap" style="width:13px;height:13px;color:#fff"></i>
