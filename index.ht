/* ─── EMAILS ─── */
let emails = [];
function addEmails(){
  const raw = document.getElementById('emailInput').value;
  const parts = raw.split(/[\n,;]+/).map(e=>e.trim()).filter(e=>e.includes('@'));
  parts.forEach(e=>{ if(!emails.includes(e)) emails.push(e); });
  document.getElementById('emailInput').value = '';
  renderEmails();
  updateStats();
  saveToLS();
}
window.addEventListener('DOMContentLoaded', function(){
  document.getElementById('emailInput').addEventListener('keydown', e=>{
    if(e.key==='Enter'){ e.preventDefault(); addEmails(); }
  });
});
function removeEmail(idx){ emails.splice(idx,1); renderEmails(); updateStats(); saveToLS(); }
function renderEmails(){
  const el = document.getElementById('emailList');
  if(!emails.length){ el.innerHTML='<div class="list-empty">No emails added yet</div>'; }
  else {
    el.innerHTML = emails.map((e,idx)=>`
      <div class="list-item">
        <div style="display:flex;align-items:center;gap:9px">
          <div style="width:28px;height:28px;border-radius:50%;background:#ede9fe;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;color:#6366f1;flex-shrink:0">${e[0].toUpperCase()}</div>
          <span>${e}</span>
        </div>
        <button class="rm" onclick="removeEmail(${idx})"><i data-lucide="x" style="width:13px;height:13px"></i></button>
      </div>`).join('');
  }
  const rb = document.getElementById('recipientBadge');
  const cb = document.getElementById('countBadge');
  if(rb) rb.textContent = emails.length + ' emails';
  if(cb) cb.textContent = emails.length + ' emails';
  i();
}

/* ─── SENDER ACCOUNTS ─── */
let senderAccounts = [];


function addAccount(){
  const raw = document.getElementById('accountInput').value;
  // Split by newlines OR commas
  const lines = raw.split(/[\n,]+/).map(l=>l.trim()).filter(l=>l.length>0);
  lines.forEach(line => {
    // Try "email - password" (with spaces) first, then "email-password" (no spaces)
    let email = '', password = '';
    const spaceMatch = line.match(/^([^\s]+@[^\s]+)\s*[-–]\s*(.+)$/);
    if(spaceMatch){
      email = spaceMatch[1].trim();
      password = spaceMatch[2].trim();
    } else {
      // No spaces: find last @ then split at next dash after domain
      const atIdx = line.lastIndexOf('@');
      if(atIdx === -1) return;
      const afterAt = line.indexOf('-', atIdx);
      if(afterAt === -1) return;
      email = line.substring(0, afterAt).trim();
      password = line.substring(afterAt + 1).trim();
    }
    if(email.includes('@') && password && !senderAccounts.find(a=>a.email===email))
      senderAccounts.push({email, password});
  });
  document.getElementById('accountInput').value='';
  renderAccounts(); updateStats(); saveToLS();
}


function toggleGateUrlInput(){
  const w = document.getElementById('gateUrlInputWrap');
  w.style.display = w.style.display === 'block' ? 'none' : 'block';
}
function applyGateUrl(){
  const url = document.getElementById('gateDirectUrl').value.trim();
  if(!url) return;
  document.getElementById('gateAdImgUrl').value = url;
  document.getElementById('gateImgPreviewImg').src = url;
  document.getElementById('gateImgPreview').style.display = 'block';
  document.getElementById('gateUrlInputWrap').style.display = 'none';
}


function removeAccount(idx){ senderAccounts.splice(idx,1); renderAccounts(); updateStats(); saveToLS(); }
function renderAccounts(){
  const el = document.getElementById('accountList');
  if(!senderAccounts.length){ el.innerHTML='<div class="list-empty">No accounts added</div>'; }
  else {
    el.innerHTML = senderAccounts.map((a,idx)=>`
      <div class="list-item">
        <div style="display:flex;align-items:center;gap:9px">
          <div style="width:28px;height:28px;border-radius:50%;background:#dcfce7;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;color:#16a34a;flex-shrink:0">${a.email[0].toUpperCase()}</div>
          <div><div style="font-weight:600;font-size:0.84rem">${a.email}</div><div style="font-size:0.7rem;color:var(--text3);letter-spacing:1px">${'•'.repeat(Math.min(a.password.length,12))}</div></div>
        </div>
        <button class="rm" onclick="removeAccount(${idx})"><i data-lucide="x" style="width:13px;height:13px"></i></button>
      </div>`).join('');
  }
  document.getElementById('accountBadge').textContent = senderAccounts.length;
  i();
}

/* ─── PROXIES ─── */
let proxies = [];
function parseProxies(){
  const raw = document.getElementById('proxyRaw').value;
  const lines = raw.split(/[\n;]+/).map(l=>l.trim()).filter(l=>l.length>0);
  proxies = [];
  lines.forEach(line => {
    const ipM   = line.match(/IP:\s*([\d.]+)/i);
    const portM = line.match(/PORT:\s*(\d+)/i);
    const userM = line.match(/USERNAME:\s*(\S+)/i);
    const passM = line.match(/PASSWORD:\s*(\S+)/i);
    if(ipM && portM){
      proxies.push({ ip:ipM[1], port:portM[1], user:userM?userM[1]:'', pass:passM?passM[1]:'' });
      return;
    }
    const p = line.split(':');
    if(p.length>=2 && p[0].match(/^\d+\.\d+/))
      proxies.push({ ip:p[0], port:p[1], user:p[2]||'', pass:p[3]||'' });
  });
  const hint = document.getElementById('proxyHint');
  hint.innerHTML = proxies.length > 0
    ? `<i data-lucide="check-circle" style="width:11px;height:11px;color:#16a34a"></i> <span style="color:#16a34a">${proxies.length} proxies parsed</span>`
    : `<i data-lucide="info" style="width:11px;height:11px"></i> Paste one or many — parsed automatically`;
  document.getElementById('proxyBadge').textContent = proxies.length;
  renderProxies();
  updateStats(); i();
}

function removeProxy(idx){ proxies.splice(idx,1); renderProxies(); document.getElementById('proxyBadge').textContent=proxies.length; updateStats(); }

function renderProxies(){
  const el = document.getElementById('proxyList');
  if(!el) return;
  if(!proxies.length){ el.innerHTML='<div class="list-empty">No proxies added</div>'; return; }
  el.innerHTML = proxies.map((p,idx)=>`
    <div class="list-item">
      <div style="display:flex;align-items:center;gap:9px">
        <div style="width:28px;height:28px;border-radius:50%;background:#dbeafe;display:flex;align-items:center;justify-content:center;font-size:0.65rem;font-weight:700;color:#2563eb;flex-shrink:0">IP</div>
        <div>
          <div style="font-weight:600;font-size:0.82rem">${p.ip}:${p.port}</div>
          <div style="font-size:0.7rem;color:var(--text3)">${p.user ? p.user : 'no auth'}</div>
        </div>
      </div>
      <button class="rm" onclick="removeProxy(${idx})"><i data-lucide="x" style="width:13px;height:13px"></i></button>
    </div>`).join('');
  i();
}


