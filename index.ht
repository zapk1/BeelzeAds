window.addEventListener('DOMContentLoaded', function(){
  if (!campaigns.length) {
    const old = JSON.parse(localStorage.getItem('beelzeBanners') || '[]');
    if (old.length) {
      campaigns = old.map(b => ({ id: b.id||('biz_'+Date.now()), name: b.label||'Business', slogan:'', url: b.url||'', phone: b.phone||'', images: b.img ? [b.img] : [], createdAt: b.createdAt||Date.now() }));
      saveCampaigns(); renderBannerList();
    }
  }
});

