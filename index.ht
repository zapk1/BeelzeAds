    </div>`).join('');
  i();
}

/* ─── IMAGES ─── */
let uploadedImages = [];
const IMGBB_KEY = '7582cc8e40651016b8391c34b4216727';

function addDirectUrl(){
  const url=document.getElementById('directImgUrl').value.trim(); if(!url) return;
  const idx=uploadedImages.length; uploadedImages.push({name:url,url});
  addImgCard(url,url,idx);
  document.getElementById('directImgUrl').value='';
  document.getElementById('urlInputWrap').style.display='none';
}
async function uploadImages(files){
  const status = document.getElementById('uploadStatus');
  for(const file of files){
    const idx = uploadedImages.length;
    uploadedImages.push(null);
    status.innerHTML = `<div style="margin-bottom:8px;"><div style="font-size:0.78rem;color:#555;margin-bottom:5px;">Uploading <strong>${file.name}</strong>...</div><div style="background:#e5e7eb;border-radius:99px;height:6px;overflow:hidden;"><div id="uploadBar" style="height:100%;width:0%;background:linear-gradient(90deg,#6366f1,#8b5cf6);border-radius:99px;transition:width 0.3s;"></div></div></div>`;
    let prog=0;
    const barTimer=setInterval(()=>{ prog=Math.min(prog+Math.random()*18,85); const b=document.getElementById('uploadBar'); if(b) b.style.width=prog+'%'; },200);
    const form=new FormData(); form.append('image',file);
    const res=await fetch(`https://api.imgbb.com/1/upload?key=${IMGBB_KEY}`,{method:'POST',body:form});
    const data=await res.json();
    clearInterval(barTimer);
    const b=document.getElementById('uploadBar'); if(b) b.style.width='100%';
    if(data.success){
      const url=data.data.url;
      uploadedImages[idx]={name:file.name,url};
      setTimeout(()=>{ status.innerHTML=`<div style="font-size:0.78rem;color:#16a34a;margin-bottom:8px;">✓ ${file.name} uploaded!</div>`; addImgCard(url,file.name,idx); },300);
    } else {
      status.innerHTML=`<div style="font-size:0.78rem;color:#ef4444;margin-bottom:8px;">✕ Upload failed</div>`;
    }
  }
  document.getElementById('imgInput').value='';
}

function addImgCard(url,name,idx){
  const grid=document.getElementById('imgGrid'); const div=document.createElement('div');
  div.className='img-card'; div.id='imgcard_'+idx;
  div.innerHTML=`<button class="rm-btn" onclick="removeImg(${idx})" style="position:absolute;top:5px;right:5px;background:rgba(0,0,0,0.6);border:none;border-radius:50%;width:24px;height:24px;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:2;"><i data-lucide="x" style="width:12px;height:12px"></i></button><img src="${url}" alt="${name}" style="width:100%;height:80px;object-fit:cover;display:block;border-radius:10px 10px 0 0;"/><div style="padding:5px 7px;font-size:0.65rem;color:#666;word-break:break-all;">${name.length>22?name.substring(0,22)+'…':name}</div>`;
  grid.appendChild(div); i();
}
function removeImg(idx){ uploadedImages[idx]=null; const el=document.getElementById('imgcard_'+idx); if(el) el.remove(); }

/* ─── STATS ─── */
function updateStats(){
  const s1 = document.getElementById('statSent');
  const s2 = document.getElementById('statRecipients');
  const s3 = document.getElementById('statProxies');
  const s4 = document.getElementById('statAccounts');
  if(s1) s1.textContent = sessionSent;
  if(s2) s2.textContent = emails.length;
  if(s3) s3.textContent = proxies.length;
  if(s4) s4.textContent = senderAccounts.length;
}
let sessionSent = 0;

/* ─── LOCALSTORAGE PERSISTENCE ─── */
function saveToLS() {
  localStorage.setItem('beelze_emails',   JSON.stringify(emails));
  localStorage.setItem('beelze_accounts', JSON.stringify(senderAccounts));
  localStorage.setItem('beelze_proxies',  JSON.stringify(proxies));
  localStorage.setItem('beelze_proxyRaw', document.getElementById('proxyRaw').value);
  localStorage.setItem('beelze_domains',  JSON.stringify(domains));
  localStorage.setItem('beelze_images',   JSON.stringify(uploadedImages.filter(Boolean)));
  localStorage.setItem('beelze_subject',  document.getElementById('cSubject').value);
  localStorage.setItem('beelze_body',     document.getElementById('cBody').value);
  localStorage.setItem('beelze_sender',   document.getElementById('cSenderName').value);
  localStorage.setItem('beelze_smtpHost', document.getElementById('smtpHost').value);
  localStorage.setItem('beelze_smtpPort', document.getElementById('smtpPort').value);
}

function loadFromLS() {
  emails          = JSON.parse(localStorage.getItem('beelze_emails')   || '[]');
  senderAccounts  = JSON.parse(localStorage.getItem('beelze_accounts') || '[]');
  proxies         = JSON.parse(localStorage.getItem('beelze_proxies')  || '[]');
  domains         = JSON.parse(localStorage.getItem('beelze_domains')  || '[]');
  uploadedImages  = JSON.parse(localStorage.getItem('beelze_images')   || '[]');

  const proxyRaw  = localStorage.getItem('beelze_proxyRaw');
  if (proxyRaw)  document.getElementById('proxyRaw').value      = proxyRaw;
  const subject   = localStorage.getItem('beelze_subject');
  if (subject)   document.getElementById('cSubject').value      = subject;
  const body      = localStorage.getItem('beelze_body');
  if (body)      document.getElementById('cBody').value         = body;
  const sender    = localStorage.getItem('beelze_sender');
  if (sender)    document.getElementById('cSenderName').value   = sender;
  const smtpHost  = localStorage.getItem('beelze_smtpHost');
  if (smtpHost)  document.getElementById('smtpHost').value      = smtpHost;
  const smtpPort  = localStorage.getItem('beelze_smtpPort');
  if (smtpPort)  document.getElementById('smtpPort').value      = smtpPort;

  renderEmails(); renderAccounts(); renderDomains(); updateStats();

  // Re-render images
  uploadedImages.forEach((img, idx) => { if(img) addImgCard(img.url, img.name, idx); });

  // Proxy count badge
  document.getElementById('proxyBadge').textContent = proxies.length;
}



