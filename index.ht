/* ─── NAVIGATION ─── */
const pageTitles = {
  dashboard: ['__BEELZE__', 'Good morning, Beelze 👋'],
  compose:   ['New Campaign', 'Compose your email blast'],
  recipients:['Recipients', 'Manage your email list'],
  config:    ['Setup', 'Accounts & proxy config'],
  ads:       ['Advertising', 'Ad placements & revenue'],
  settings:  ['Settings', 'App preferences'],
};

function goPage(name){
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page' + name.charAt(0).toUpperCase() + name.slice(1)).classList.add('active');
  const navEl = document.getElementById('nav-' + name);
  if(navEl) navEl.classList.add('active');
    const titles = pageTitles[name] || [name, ''];
  if (titles[0] === '__BEELZE__') {
    startBeelzeAnim();
  } else {
    stopBeelzeAnim();
    document.getElementById('pageTitle').textContent = titles[0];
  }
  document.getElementById('pageSubtitle').textContent = titles[1];
  window.scrollTo({ top: 0, behavior: 'smooth' });
  i();
}

