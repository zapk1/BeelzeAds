          <div class="settings-icon" style="background:#5e5ce6"><i data-lucide="book-open" style="width:15px;height:15px;color:#fff"></i></div>
          <div><h4>How to Use</h4><p>Step-by-step guide</p></div>
        </div>
        <i data-lucide="chevron-right" class="chevron"></i>
      </div>
