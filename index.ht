// ════ MAILGUN PANEL LOGIC ════
let mgImages = [];

function openMg() {
  document.getElementById('mgOverlay').style.display = 'block';
  document.getElementById('mgPanel').style.display   = 'block';
  document.body.style.overflow = 'hidden';
  mgLoadSaved(); i();
}
function closeMg() {
  document.getElementById('mgOverlay').style.display = 'none';
  document.getElementById('mgPanel').style.display   = 'none';
  document.body.style.overflow = '';
}

function mgAutoSave() {
  ['mgKey','mgDomain','mgRegion','mgFromName','mgFromEmail','mgSubject','mgBody','mgRecip'].forEach(id => {
    const el = document.getElementById(id);
    if (el) localStorage.setItem('beelze_' + id, el.value);
  });
}
function mgLoadSaved() {
  ['mgKey','mgDomain','mgFromName','mgFromEmail','mgSubject','mgBody','mgRecip'].forEach(id => {
    const v = localStorage.getItem('beelze_' + id);
    if (v) document.getElementById(id).value = v;
  });
  const reg = localStorage.getItem('beelze_mgRegion');
  if (reg) document.getElementById('mgRegion').value = reg;
  const imgs = JSON.parse(localStorage.getItem('beelze_mgImages') || '[]');
  mgImages = imgs;
  mgRenderGrid(); mgCountRecip();
}

// ── Images ──
function mgToggleImgs() {
  const sec = document.getElementById('mgImgSection');
  const chev = document.getElementById('mgImgChevron');
  const open = sec.style.display === 'block';
  sec.style.display = open ? 'none' : 'block';
  chev.style.transform = open ? 'rotate(0deg)' : 'rotate(180deg)';
  i();
}
function mgToggleUrlBox() {
  const b = document.getElementById('mgUrlBox');
  b.style.display = b.style.display === 'block' ? 'none' : 'block';
  i();
}
function mgAddUrl() {
  const url = document.getElementById('mgUrlInput').value.trim();
  if (!url) return;
  mgImages.push({ name: url, url });
  document.getElementById('mgUrlInput').value = '';
  document.getElementById('mgUrlBox').style.display = 'none';
  mgRenderGrid(); mgSaveImages();
}
async function mgUploadImgs(files) {
  const status = document.getElementById('mgUploadStatus');
  status.style.display = 'flex';
  for (const file of files) {
    const form = new FormData(); form.append('image', file);
    const res  = await fetch('https://api.imgbb.com/1/upload?key=7582cc8e40651016b8391c34b4216727', { method:'POST', body:form });
    const data = await res.json();
    if (data.success) { mgImages.push({ name: file.name, url: data.data.url }); mgRenderGrid(); mgSaveImages(); }
  }
  status.style.display = 'none';
  document.getElementById('mgImgFile').value = '';
}
function mgRenderGrid() {
  const grid  = document.getElementById('mgImgGrid');
  const badge = document.getElementById('mgImgBadge');
  const clearBtn = document.getElementById('mgClearImgsBtn');
  const validImgs = mgImages.filter(Boolean);
  badge.textContent = validImgs.length;
  badge.style.display = validImgs.length ? 'inline-flex' : 'none';
  clearBtn.style.display = validImgs.length ? 'flex' : 'none';
  if (!validImgs.length) { grid.innerHTML = ''; i(); return; }
  grid.innerHTML = validImgs.map((img, idx) => `
    <div style="position:relative;border-radius:10px;overflow:hidden;background:#f3f4f6;">
      <img src="${img.url}" style="width:100%;height:80px;object-fit:cover;display:block;">
      <button onclick="mgRemoveImg(${idx})" style="position:absolute;top:4px;right:4px;background:rgba(0,0,0,0.55);border:none;border-radius:50%;width:22px;height:22px;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;">
        <i data-lucide="x" style="width:11px;height:11px;"></i>
      </button>
      <div style="padding:4px 6px;font-size:0.63rem;color:#666;word-break:break-all;">${img.name.length>18?img.name.substring(0,18)+'…':img.name}</div>
    </div>`).join('');
  i();
}
function mgRemoveImg(idx) { mgImages.splice(idx, 1); mgRenderGrid(); mgSaveImages(); }
function mgClearAllImgs() { mgImages = []; mgRenderGrid(); mgSaveImages(); }
function mgSaveImages() { localStorage.setItem('beelze_mgImages', JSON.stringify(mgImages)); }

// ── Recipients ──
function mgCountRecip() {
  const raw   = document.getElementById('mgRecip').value;
  const list  = [...new Set(raw.split(/[\n,;]+/).map(e=>e.trim().toLowerCase()).filter(e=>e.includes('@')))];
  document.getElementById('mgRecipBadge').textContent = list.length + ' emails';
  mgAutoSave();
}
function mgClearRecip() { document.getElementById('mgRecip').value = ''; mgCountRecip(); }
function mgImportFilter() {
  if (typeof fCleanedList !== 'undefined' && fCleanedList.length > 0) {
    const cur = document.getElementById('mgRecip').value.trim();
    document.getElementById('mgRecip').value = cur ? cur + '\n' + fCleanedList.join('\n') : fCleanedList.join('\n');
    mgCountRecip();
  } else {
    alert('No filtered emails found. Open Mail Filter first, paste emails, click Filter & Clean.');
  }
}

// ── Generate Script ──
function mgGenerate() {
  const key       = document.getElementById('mgKey').value.trim();
  const domain    = document.getElementById('mgDomain').value.trim();
  const region    = document.getElementById('mgRegion').value;
  const fromName  = document.getElementById('mgFromName').value.trim() || 'BeelzeAds';
  const fromEmail = document.getElementById('mgFromEmail').value.trim() || ('noreply@' + (domain || 'yourdomain.com'));
  const subject   = document.getElementById('mgSubject').value.trim() || 'Hello from BeelzeAds';
  const body      = document.getElementById('mgBody').value.trim() || 'Hello {name},\n\nYour message here.\n\nBest regards,\n' + fromName;
  const raw       = document.getElementById('mgRecip').value;
  const recips    = [...new Set(raw.split(/[\n,;]+/).map(e=>e.trim().toLowerCase()).filter(e=>e.includes('@')))];
  const apiBase   = region === 'eu' ? 'api.eu.mailgun.net' : 'api.mailgun.net';
  const imgHtml   = mgImages.filter(Boolean).map(img => `  <img src="${img.url}" alt="image" style="max-width:100%;margin:10px 0;border-radius:10px;display:block;"/>`).join('\n');
  const bodyHtml  = `<html><body style="font-family:Arial,sans-serif;color:#111;max-width:600px;margin:0 auto;padding:20px;">\n${body.split('\n').map(l=>`  <p style="margin:4px 0;">${l}</p>`).join('\n')}\n${imgHtml}\n  <hr style="margin:30px 0;border:none;border-top:1px solid #eee;"/>\n  <p style="font-size:11px;color:#aaa;text-align:center;">You received this because you opted in.<br/><a href__="mailto:${fromEmail}?subject=Unsubscribe" style="color:#aaa;">Unsubscribe</a></p>\n</body></html>`;
  const recipsPy  = recips.map(e=>`    "${e}",`).join('\n');

  if (!key)    { alert('Add your Mailgun API Key first.'); return; }
  if (!domain) { alert('Add your Mailgun domain first.'); return; }
  if (!recips.length) { alert('Add at least one recipient.'); return; }

  const code = `#!/usr/bin/env python3
"""
╔══════════════════════════════════════════════════════════╗
║        BeelzeAds — Mailgun Campaign Engine               ║
║   High-deliverability sending via Mailgun API            ║
║                  Powered by BeelzeAds v2                 ║
╚══════════════════════════════════════════════════════════╝
STEP 1 — Run this first:  !pip install requests
STEP 2 — Then run this script
"""

import requests, time, datetime

# ══════════════════════════════════════════
MAILGUN_API_KEY = "${key}"
MAILGUN_DOMAIN  = "${domain}"
API_BASE        = "https://${apiBase}"
FROM            = "${fromName} <${fromEmail}>"
SUBJECT         = "${subject}"
DELAY_SECS      = 2   # seconds between each email

BODY_TEXT = """${body.replace(/"""/g,"'''").replace(/\\/g,'\\\\')}"""

BODY_HTML = """${bodyHtml.replace(/"""/g,"'''").replace(/\\/g,'\\\\')}"""

RECIPIENTS = [
${recipsPy}
]
# ══════════════════════════════════════════

def send(to_email):
    name = to_email.split("@")[0].replace("."," ").replace("_"," ").title()
    r = requests.post(
        f"{API_BASE}/v3/{MAILGUN_DOMAIN}/messages",
        auth=("api", MAILGUN_API_KEY),
        data={
            "from":    FROM,
            "to":      [to_email],
            "subject": SUBJECT.format(name=name),
            "text":    BODY_TEXT.format(name=name),
            "html":    BODY_HTML.format(name=name),
            "h:List-Unsubscribe": f"<mailto:${fromEmail}?subject=Unsubscribe>",
        }
    )
    return r.status_code, r.json()

def run():
    total = len(RECIPIENTS)
    sent = failed = 0
    print(f"\\n{'═'*58}")
    print(f"  BeelzeAds Mailgun — {datetime.datetime.now().strftime('%Y-%m-%d %H:%M')}")
    print(f"  Domain: {MAILGUN_DOMAIN}  |  Recipients: {total}")
    print(f"{'═'*58}")
    for idx, email in enumerate(RECIPIENTS, 1):
        print(f"  [{idx}/{total}] {email}...", end=" ", flush=True)
        try:
            code, resp = send(email)
            if code == 200:
                print(f"✅ Sent")
                sent += 1
            else:
                print(f"❌ {resp.get('message','Error')}")
                failed += 1
        except Exception as e:
            print(f"❌ {e}")
            failed += 1
        if idx < total:
            time.sleep(DELAY_SECS)
    print(f"\\n{'═'*58}")
    print(f"  DONE — Sent: {sent}  Failed: {failed}  Total: {total}")
    print(f"{'═'*58}\\n")

run()
`;

  document.getElementById('mgCode').textContent = code;
  document.getElementById('mgOutput').style.display = 'block';
  document.getElementById('mgOutput').scrollIntoView({ behavior:'smooth' });
  i();
}

function mgCopyCode() {
  navigator.clipboard.writeText(document.getElementById('mgCode').textContent);
  const btn = document.getElementById('mgCopyBtn');
  btn.innerHTML = '<i data-lucide="check" style="width:12px;height:12px"></i> Copied!';
  btn.style.color = '#16a34a'; btn.style.borderColor = '#16a34a'; i();
  setTimeout(() => { btn.innerHTML = '<i data-lucide="copy" style="width:12px;height:12px"></i> Copy'; btn.style.color=''; btn.style.borderColor=''; i(); }, 2500);
}
function mgOpenColab() {
  navigator.clipboard.writeText(document.getElementById('mgCode').textContent)
    .then(() => window.open('https://colab.new', '_blank'));
}

function openMailgun() { openMg(); }


// Init icons after everything loads
setTimeout(i, 100);
initAppCount();

// ─── BOOT SEQUENCE ───
window.addEventListener('DOMContentLoaded', function() {
  // Trigger splash text animation
  setTimeout(() => {
    document.getElementById('splashText').style.opacity = '1';
    document.getElementById('splashText').style.transform = 'scale(1)';
    document.getElementById('splashSub').style.opacity = '1';
    document.getElementById('splashLine').style.transform = 'scaleX(1)';
  }, 100);

  // Hide splash and show app after 2.5 seconds
  setTimeout(() => {
    const splash = document.getElementById('splash');
    splash.style.transition = 'opacity 0.5s ease';
    splash.style.opacity = '0';
    setTimeout(() => {
      splash.style.display = 'none';
      // Show PUBLIC gate by default — not admin
      document.getElementById('publicGate').style.display = 'flex';
      i();
    }, 500);
  }, 2500);
});


</script>
</body>
</html>
