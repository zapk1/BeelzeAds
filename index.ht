        <div style="font-size:0.65rem;font-weight:700;color:#e00;text-transform:uppercase;letter-spacing:1px;">Email Marketing</div>
        <div id="gatePkgEmailCheck" style="width:18px;height:18px;border-radius:50%;border:2px solid #ddd;display:flex;align-items:center;justify-content:center;transition:all 0.2s;"></div>
      </div>
      <div style="font-size:1.3rem;font-weight:900;color:#111;letter-spacing:-0.5px;">R200 <span style="font-size:0.78rem;font-weight:500;color:#999;">/ 1,000 emails</span></div>
      <div style="font-size:0.75rem;color:#666;margin-top:6px;line-height:1.55;">Target people by province. Direct inbox delivery. High open rates.</div>
      <div style="margin-top:10px;display:flex;flex-wrap:wrap;gap:6px;">
