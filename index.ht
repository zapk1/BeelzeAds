  <!-- ═══ PAGE: ADS ═══ -->
  <div class="page" id="pageAds" style="padding-top:8px">
    <div class="section-title">Advertising Dashboard</div>

    <!-- EARNINGS CARD -->
    <div class="card" style="background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
        <div>
          <p style="font-size:0.72rem;opacity:0.7;font-weight:600;text-transform:uppercase;letter-spacing:0.5px">Est. Monthly Revenue</p>
          <p style="font-size:2.2rem;font-weight:900;letter-spacing:-1px;margin-top:4px">$0.00</p>
          <p style="font-size:0.75rem;opacity:0.7;margin-top:2px">Grows with traffic</p>
        </div>
        <div style="width:52px;height:52px;background:rgba(255,255,255,0.15);border-radius:16px;display:flex;align-items:center;justify-content:center">
          <i data-lucide="trending-up" style="width:26px;height:26px;color:#fff"></i>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px">
        <div style="background:rgba(255,255,255,0.1);border-radius:10px;padding:10px;text-align:center">
          <p style="font-size:1rem;font-weight:800">0</p>
          <p style="font-size:0.65rem;opacity:0.7">Impressions</p>
        </div>
        <div style="background:rgba(255,255,255,0.1);border-radius:10px;padding:10px;text-align:center">
          <p style="font-size:1rem;font-weight:800">0</p>
          <p style="font-size:0.65rem;opacity:0.7">Clicks</p>
        </div>
        <div style="background:rgba(255,255,255,0.1);border-radius:10px;padding:10px;text-align:center">
          <p style="font-size:1rem;font-weight:800">0%</p>
          <p style="font-size:0.65rem;opacity:0.7">CTR</p>
        </div>
      </div>
    </div>

    <!-- AD UNITS -->
    <div class="section-title">Ad Placements</div>

    <div class="ad-unit-card">
      <div class="ad-unit-header">
        <h3><i data-lucide="layout-top" style="width:16px;height:16px;color:var(--accent)"></i> Adsterra Units</h3>
        <span class="badge badge-green">Live</span>
      </div>
      <div class="ad-unit-body">
        <div class="ad-placement">
          <div class="ad-placement-left">
            <div class="ad-placement-icon"><i data-lucide="home"></i></div>
            <div>
              <h4>Homepage Banner</h4>
              <p>Below header · High visibility</p>
            </div>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" checked onchange="toggleAd(this,'home')">
            <span class="toggle-slider"></span>
          </label>
        </div>
        <div class="ad-placement">
          <div class="ad-placement-left">
            <div class="ad-placement-icon"><i data-lucide="shopping-cart"></i></div>
            <div>
              <h4>Checkout Page</h4>
              <p>Pre-payment · Max intent</p>
            </div>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" checked onchange="toggleAd(this,'checkout')">
            <span class="toggle-slider"></span>
          </label>
        </div>
        <div class="ad-placement">
          <div class="ad-placement-left">
            <div class="ad-placement-icon"><i data-lucide="grid-2x2"></i></div>
            <div>
              <h4>Product Grid</h4>
              <p>Between products</p>
            </div>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" onchange="toggleAd(this,'grid')">
            <span class="toggle-slider"></span>
          </label>
        </div>
        <div class="ad-placement">
          <div class="ad-placement-left">
            <div class="ad-placement-icon"><i data-lucide="receipt"></i></div>
            <div>
              <h4>Order Confirmation</h4>
              <p>Post-purchase page</p>
            </div>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" onchange="toggleAd(this,'confirm')">
            <span class="toggle-slider"></span>
          </label>
        </div>
      </div>
    </div>

    <!-- AD SCRIPT -->
    <div class="section-title">Ad Script Snippet</div>
    <div class="card">
      <div class="card-header"><i data-lucide="code"></i> Adsterra Embed Code</div>
      <p style="font-size:0.8rem;color:var(--text2);margin-bottom:12px;line-height:1.6">Copy and paste this wherever you want the ad to appear on your site. Works on localhost only after publishing to a live domain.</p>
      <div class="code-wrap">
        <div class="code-header">
          <span><i data-lucide="code-2"></i> HTML Snippet</span>
          <button class="copy-btn" onclick="copySnippet()"><i data-lucide="copy" style="width:12px;height:12px"></i> Copy</button>
        </div>
        <pre class="code-box" id="adSnippet">&lt;div style="text-align:center;padding:8px;"&gt;
  &lt;script async="async" data-cfasync="false"
    src="https://pl29493431.effectivecpmnetwork.com/ccd11bb2031421a7a4ea2997af2632c9/invoke.js"&gt;
  &lt;/script&gt;
  &lt;div id="container-ccd11bb2031421a7a4ea2997af2632c9"&gt;&lt;/div&gt;
&lt;/div&gt;</pre>
      </div>
      <div class="warn-box" style="margin-top:12px;margin-bottom:0">
        <i data-lucide="alert-triangle"></i>
        <p>Ads only display on live published domains — not on localhost. Test on your real URL after deploying.</p>
      </div>
    </div>

  </div>

