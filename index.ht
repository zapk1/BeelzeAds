<script>
function i(){ if(typeof lucide!=='undefined') lucide.createIcons(); }

function openAppsLogin(){
  // Bury the gate so modal appears on top
  var gate = document.getElementById('publicGate');
  if(gate) gate.style.zIndex = '1';
  document.getElementById('appsLoginOverlay').style.cssText = 'display:block;position:fixed;inset:0;background:rgba(0,0,0,0.65);z-index:9998;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);';
  document.getElementById('appsLoginModal').style.cssText = 'display:block;position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:9999;width:min(340px,92vw);background:#000;border-radius:24px;padding:36px 28px;box-shadow:0 30px 80px rgba(0,0,0,0.6);border:1px solid #222;font-family:Inter,sans-serif;';
  setTimeout(()=>{ var i=document.getElementById('appsPwInput'); if(i) i.focus(); },100);
  loadAppCount();
}
function closeAppsLogin(){
  document.getElementById('appsLoginOverlay').style.cssText = 'display:none !important;position:fixed;';
  document.getElementById('appsLoginModal').style.cssText = 'display:none !important;position:fixed;';
  var gate = document.getElementById('publicGate');
  if(gate) gate.style.zIndex = '';
  var inp = document.getElementById('appsPwInput');
  var err = document.getElementById('appsPwError');
  if(inp) inp.value='';
  if(err) err.style.display='none';
}
function checkAppsPw(){
  var inp = document.getElementById('appsPwInput');
  var err = document.getElementById('appsPwError');
  if(inp && inp.value==='VNAXXTTM'){
    closeAppsLogin();
    var panel = document.getElementById('appsPanel');
    panel.style.cssText = 'display:block;position:fixed;inset:0;z-index:9997;background:#f5f5f5;overflow-y:auto;font-family:Inter,sans-serif;';
    document.body.style.overflow='hidden';
    loadApplications();
  } else {
    if(err) err.style.display='block';
    if(inp){ inp.value=''; inp.focus(); }
  }
}
function closeAppsPanel(){
  var panel = document.getElementById('appsPanel');
  if(panel) panel.style.cssText = 'display:none !important;position:fixed;';
  document.body.style.overflow='';
}


function confirmPayment(){
  document.getElementById('paymentPage').style.display='none';
  document.body.style.overflow='';
  alert('Thank you! We will verify your payment and activate your ads within 24 hours. ✅');
}


