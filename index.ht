        <span style="font-size:0.65rem;font-weight:600;background:#fff5f5;color:#e00;padding:3px 10px;border-radius:99px;border:1px solid #ffd0d0;">✓ Bulk delivery</span>
        <span style="font-size:0.65rem;font-weight:600;background:#fff5f5;color:#e00;padding:3px 10px;border-radius:99px;border:1px solid #ffd0d0;">✓ HTML design</span>
      </div>
      <button style="margin-top:14px;width:100%;padding:11px;background:#e00;color:#fff;border:none;border-radius:12px;font-size:0.82rem;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;letter-spacing:0.3px;">Select Plan</button>
    </div>

    <!-- NATIVE PACKAGE -->
    <div id="gatePkgNative" onclick="gateSelectPkg('native',this)" style="background:#fff;border:2px solid #eee;border-radius:18px;padding:18px 20px;cursor:pointer;margin-bottom:20px;position:relative;overflow:hidden;transition:border 0.2s,box-shadow 0.2s;">
      <div style="position:absolute;top:0;left:0;width:4px;height:100%;background:#e00;border-radius:18px 0 0 18px;"></div>
