// ─── CONTROLLER DRAG ───
(function(){
  var ctrl = document.getElementById('elemController');
  var handle = document.getElementById('ctrlDragHandle');
  var ctrlDragging = false, ctrlStartX = 0, ctrlStartY = 0, ctrlOrigX = 0, ctrlOrigY = 0;
  if (handle) {
    handle.addEventListener('mousedown', function(e) {
      ctrlDragging = true;
      ctrlStartX = e.clientX;
      ctrlStartY = e.clientY;
      var rect = ctrl.getBoundingClientRect();
      ctrlOrigX = rect.left;
      ctrlOrigY = rect.top;
      ctrl.style.transform = 'none';
      ctrl.style.right = 'auto';
      ctrl.style.top = ctrlOrigY + 'px';
      ctrl.style.left = ctrlOrigX + 'px';
      handle.style.cursor = 'grabbing';
      e.preventDefault();
    });
    handle.addEventListener('touchstart', function(e) {
      ctrlDragging = true;
      var t = e.touches[0];
      ctrlStartX = t.clientX;
      ctrlStartY = t.clientY;
      var rect = ctrl.getBoundingClientRect();
      ctrlOrigX = rect.left;
      ctrlOrigY = rect.top;
      ctrl.style.transform = 'none';
      ctrl.style.right = 'auto';
      ctrl.style.top = ctrlOrigY + 'px';
      ctrl.style.left = ctrlOrigX + 'px';
      handle.style.cursor = 'grabbing';
      e.preventDefault();
    }, { passive:false });
  }
  document.addEventListener('mousemove', function(e) {
    if (!ctrlDragging) return;
    ctrl.style.left = (ctrlOrigX + e.clientX - ctrlStartX) + 'px';
    ctrl.style.top = (ctrlOrigY + e.clientY - ctrlStartY) + 'px';
  });
  document.addEventListener('touchmove', function(e) {
    if (!ctrlDragging) return;
    var t = e.touches[0];
    ctrl.style.left = (ctrlOrigX + t.clientX - ctrlStartX) + 'px';
    ctrl.style.top = (ctrlOrigY + t.clientY - ctrlStartY) + 'px';
  }, { passive:false });
  document.addEventListener('mouseup', function() { ctrlDragging = false; if(handle) handle.style.cursor='grab'; });
  document.addEventListener('touchend', function() { ctrlDragging = false; if(handle) handle.style.cursor='grab'; });
})();




// ─── FOOTER SELECTION ───
(function(){
  var footer = document.getElementById('canvasFooter');
  if (!footer) return;
  footer.setAttribute('data-id', 'canvasFooter');
  footer.style.cursor = 'pointer';

  footer.addEventListener('mousedown', function(e) {
    if (isDragging || isResizing) return;
    e.stopPropagation();
    e.preventDefault();
    // Clear selection first, then immediately set footer as selected
    document.querySelectorAll('.canvas-selected').forEach(function(el){ el.classList.remove('canvas-selected'); });
    document.querySelectorAll('.canvas-resize-handle').forEach(function(h){ h.remove(); });
    var ctrl = document.getElementById('elemController');
    if (ctrl) ctrl.style.display = 'none';
    footer.classList.add('canvas-selected');
    canvasSelectedId = 'canvasFooter';
    document.getElementById('elemController').style.display = 'flex';
  });

  footer.addEventListener('touchstart', function(e) {
    if (isDragging || isResizing) return;
    e.stopPropagation();
    document.querySelectorAll('.canvas-selected').forEach(function(el){ el.classList.remove('canvas-selected'); });
    document.querySelectorAll('.canvas-resize-handle').forEach(function(h){ h.remove(); });
    footer.classList.add('canvas-selected');
    canvasSelectedId = 'canvasFooter';
    document.getElementById('elemController').style.display = 'flex';
  }, { passive: true });
})();



// ─── BOOT SEQUENCE ───

window.addEventListener('DOMContentLoaded', function() {
  // --- SPLASH SCREEN ---
  setTimeout(() => {
    document.getElementById('splashText').style.opacity = '1';
    document.getElementById('splashText').style.transform = 'scale(1)';
    document.getElementById('splashSub').style.opacity = '1';
    document.getElementById('splashLine').style.transform = 'scaleX(1)';
  }, 100);

  // --- HIDE SPLASH & BOOT APP ---
  setTimeout(() => {
    const splash = document.getElementById('splash');
    splash.style.transition = 'opacity 0.5s ease';
    splash.style.opacity = '0';
    setTimeout(() => {
      splash.style.display = 'none';
      document.getElementById('app').style.display = 'flex';

      // 1. Load all saved data from localStorage
      mgLoadSaved();
      canvasLoadSaved(); // This rebuilds the canvas from saved elements

      // 2. Restore footer and font settings from localStorage
      const savedFooterType = localStorage.getItem('beelze_mgFooterType') || 'branded';
      setFooterType(savedFooterType, true); // Pass true to prevent re-saving
      
      const savedFont = localStorage.getItem('beelze_emailFont');
      if (savedFont) {
          const fontData = JSON.parse(savedFont);
          setEmailFont(fontData.stack, fontData.label, true); // Pass true to prevent re-saving
      }

      // 3. A single, clean update to render everything from the now-correct loaded state
      setTimeout(() => {
        mgUpdatePreview(); // This will sync header, footer, and body correctly
        i(); // Refresh icons
      }, 100);

    }, 500);
  }, 2500);
});


