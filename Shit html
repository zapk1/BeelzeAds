function applyColor(target, hex) {
  const swatchIds = { header:'headerColorSwatch', button:'btnColorSwatch', headerText:'headerTextColorSwatch', btnText:'btnTextColorSwatch' };
  const hexIds = { header:'headerColorHex', button:'btnColorHex', headerText:'headerTextColorHex', btnText:'btnTextColorHex' };
  if (document.getElementById(swatchIds[target])) {
    document.getElementById(swatchIds[target]).style.background = hex;
  }
  if (document.getElementById(hexIds[target])) {
    document.getElementById(hexIds[target]).textContent = hex;
  }
  // Apply button color to ALL canvas buttons
  if (target === 'button') {
    canvasElements.forEach(function(ce) {
      if (ce.type === 'button') {
        ce.color = hex;
        if (ce.el) ce.el.style.background = hex;
      }
