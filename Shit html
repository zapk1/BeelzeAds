let canvasElements = []; // {id,type,el,x,y,w,h,text,url,color,font}
let canvasIdCounter = 0;
let canvasSelectedId = null;
let canvasUndoStack = [];
let canvasRedoStack = [];
let canvasImgSize = 250;
let canvasImgLayout = 1;
let canvasEditingBtnId = null;
let isDragging = false;
let dragTarget = null;
let dragStartX = 0, dragStartY = 0;
let dragOrigX = 0, dragOrigY = 0;
let isResizing = false;
let resizeTarget = null;
let resizeStartW = 0, resizeStartH = 0;

function canvasSaveState() {
  canvasUndoStack.push(JSON.stringify(canvasElements));
  if (canvasUndoStack.length > 50) canvasUndoStack.shift();
  canvasRedoStack = [];
}

function canvasUndo() {
  if (!canvasUndoStack.length) return;
  canvasRedoStack.push(JSON.stringify(canvasElements));
  canvasElements = JSON.parse(canvasUndoStack.pop());
  canvasRebuildAll();
  canvasSavePreviewData();
}

function canvasRedo() {
  if (!canvasRedoStack.length) return;
  canvasUndoStack.push(JSON.stringify(canvasElements));
  canvasElements = JSON.parse(canvasRedoStack.pop());
  canvasRebuildAll();
  canvasSavePreviewData();
}

