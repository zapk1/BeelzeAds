<script>
function i(){ if(typeof lucide!=='undefined') lucide.createIcons(); }


// Trigger splash text animation
window.addEventListener('load', function(){
  setTimeout(() => {
    document.getElementById('splashText').style.opacity = '1';
    document.getElementById('splashText').style.transform = 'scale(1)';
