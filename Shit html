      topImg.style.borderRadius = '8px';
      topImg.style.display = 'inline-block';
      topLogoWrap.appendChild(topImg);
      canvas.insertBefore(topLogoWrap, header);
    } else if (logoState.position === 'left') {
      header.style.display = 'flex';
      header.style.alignItems = 'center';
      header.style.gap = '14px';
      header.style.textAlign = 'left';
      logoImg.style.margin = '0';
      logoImg.style.flexShrink = '0';
      header.insertBefore(logoImg, headerText);
    } else if (logoState.position === 'center') {
      logoImg.style.margin = '0 auto';
      header.innerHTML = '';
      header.appendChild(logoImg);
      header.appendChild(headerText);
      header.style.display = 'block';
      header.style.textAlign = 'center';
    }
  }
}

