let textEditingId = null;
const textEditFonts = [
  ['Arial,Helvetica,sans-serif','Arial'],['Georgia,serif','Georgia'],['Verdana,Geneva,sans-serif','Verdana'],
  ['Trebuchet MS,sans-serif','Trebuchet'],['Courier New,monospace','Courier'],['Palatino Linotype,serif','Palatino'],
  ['Tahoma,Geneva,sans-serif','Tahoma'],['Lucida Console,monospace','Lucida'],['Impact,sans-serif','Impact'],['Times New Roman,serif','Times']
];
let textEditSelectedFont = 'Arial,Helvetica,sans-serif';

function buildTextEditFontGrid() {
  var grid = document.getElementById('textEditFontGrid');
  grid.innerHTML = textEditFonts.map(function(f){
    var selected = f[0] === textEditSelectedFont;
    return '<button onclick="textEditPickFont(\'' + f[0] + '\',\'' + f[1] + '\')" class="fontBtn" data-font="' + f[1] + '" style="padding:9px 6px;background:' + (selected ? '#000' : '#f5f5f5') + ';color:' + (selected ? '#fff' : '#333') + ';border:1.5px solid ' + (selected ? '#000' : '#e0e0e0') + ';border-radius:8px;cursor:pointer;font-family:' + f[0] + ';font-size:0.74rem;font-weight:600;text-align:left;display:flex;align-items:center;gap:5px;"><i data-lucide="type" style="width:12px;height:12px;stroke-width:2.5;"></i> ' + f[1] + '</button>';
  }).join('');
  i();
}

function textEditPickFont(fontStack, label) {
  textEditSelectedFont = fontStack;
  document.querySelectorAll('#textEditFontGrid .fontBtn').forEach(function(btn){
    if (btn.dataset.font === label) { btn.style.background='#000'; btn.style.color='#fff'; btn.style.borderColor='#000'; }
    else { btn.style.background='#f5f5f5'; btn.style.color='#333'; btn.style.borderColor='#e0e0e0'; }
  });
}

function openTextEditPopup(id) {
  textEditingId = id;
  var elem = canvasElements.find(function(e){ return e.id === id; });
  if (!elem) return;
  document.getElementById('textEditInput').value = elem.text || '';
  textEditSelectedFont = elem.font || (typeof emailFont !== 'undefined' ? emailFont : 'Arial,Helvetica,sans-serif');
  buildTextEditFontGrid();
  document.getElementById('textEditOverlay').style.display = 'block';
  document.getElementById('textEditPopup').style.display = 'block';
  document.body.style.overflow = 'hidden';
  i();
}

function closeTextEditPopup() {
  document.getElementById('textEditOverlay').style.display = 'none';
  document.getElementById('textEditPopup').style.display = 'none';
  document.body.style.overflow = '';
  textEditingId = null;
}

function saveTextEdit() {
  if (!textEditingId) { closeTextEditPopup(); return; }
  canvasSaveState();
  var txt = document.getElementById('textEditInput').value.trim() || ' ';
  var elem = canvasElements.find(function(e){ return e.id === textEditingId; });
  if (elem) {
    elem.text = txt;
    elem.font = textEditSelectedFont;
