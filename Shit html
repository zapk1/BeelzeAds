// ─── MAIL FILTER PANEL ───
let fCleanedList = [];
let fDupesOpen   = false;

function openFilter()  {
  document.getElementById('filterOverlay').style.display = 'block';
  document.getElementById('filterPanel').style.display   = 'block';
  document.body.style.overflow = 'hidden';
  i();
}
function closeFilter() {
  document.getElementById('filterOverlay').style.display = 'none';
  document.getElementById('filterPanel').style.display   = 'none';
  document.body.style.overflow = '';
}

function fUpdateCount() {
  const raw = document.getElementById('fInputEmails').value;
  const n   = raw.split(/[\n,]+/).map(e=>e.trim()).filter(e=>e.length>0).length;
  document.getElementById('fInputCount').textContent = n;
  i();
}

function fFilter() {
  const raw = document.getElementById('fInputEmails').value.trim();
  if(!raw) { fToast('Paste some emails first','alert-circle'); return; }
  const parts = raw.split(/[\n,]+/).map(e=>e.trim().toLowerCase()).filter(e=>e.length>0);
  let valid=[], invalid=0;
  parts.forEach(e=>{ /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(e) ? valid.push(e) : invalid++; });
  const total=parts.length, seen={}, unique=[], dupeMap={};
  let dupeCount=0;
  valid.forEach(e=>{ if(seen[e]){ seen[e]++; dupeMap[e]=seen[e]; dupeCount++; } else { seen[e]=1; unique.push(e); } });
  fCleanedList=unique;
  const out=document.getElementById('fOutput');
  if(unique.length>0){ out.style.color='#0a0a0a'; out.style.fontStyle='normal'; out.textContent=unique.map(e=>e+',').join('\n'); }
  else { out.style.color='#bbb'; out.style.fontStyle='italic'; out.textContent='No valid emails found.'; }
  document.getElementById('fOutputCount').textContent=unique.length;
  document.getElementById('fStatTotal').textContent=total;
  document.getElementById('fStatClean').textContent=unique.length;
  document.getElementById('fStatDupes').textContent=dupeCount;
  document.getElementById('fStatInvalid').textContent=invalid;
  fRenderDupes(dupeMap,dupeCount);
  fToast(`${unique.length} clean · ${dupeCount} dupes removed`,'check-circle-2');
  i();
}

function fRenderDupes(map,count) {
  const badge=document.getElementById('fDupeBadge');
  const empty=document.getElementById('fDupEmpty');
  const btn  =document.getElementById('fToggleDupBtn');
  const list =document.getElementById('fDupList');
  badge.innerHTML=`<i data-lucide="x-circle" style="width:10px;height:10px;"></i> ${count} found`;
  if(count===0){ empty.style.display='flex'; btn.style.display='none'; list.innerHTML=''; document.getElementById('fDupWrap').style.maxHeight='0'; i(); return; }
  empty.style.display='none'; btn.style.display='flex';
  const entries=Object.entries(map).sort((a,b)=>b[1]-a[1]);
  list.innerHTML=`<div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#8a8a8a;margin-bottom:10px;display:flex;align-items:center;gap:6px;"><i data-lucide="repeat" style="width:11px;height:11px;"></i>${entries.length} address${entries.length>1?'es':''} appeared more than once</div>`
    +entries.map(([email,count])=>`<div style="display:flex;align-items:center;gap:8px;padding:7px 10px;background:#fff;border:1px solid #e0e0e0;border-radius:6px;margin-bottom:5px;font-family:'Courier New',monospace;font-size:0.8rem;color:#5a5a5a;"><i data-lucide="alert-circle" style="width:12px;height:12px;color:#c0392b;flex-shrink:0;"></i>${email}<span style="margin-left:auto;background:#f1f3f5;border:1px solid #e0e0e0;border-radius:20px;font-size:0.7rem;font-weight:700;color:#5a5a5a;padding:2px 8px;">×${count+1}</span></div>`).join('');
  i();
}

function fToggleDupes() {
  fDupesOpen=!fDupesOpen;
  document.getElementById('fDupWrap').style.maxHeight=fDupesOpen?'400px':'0';
  document.getElementById('fDupBtnText').textContent=fDupesOpen?'Hide':'Show';
  document.getElementById('fDupChevron').setAttribute('data-lucide', fDupesOpen?'chevron-up':'chevron-down');
  i();
}

function fCopyAll() {
  if(!fCleanedList.length){ fToast('Nothing to copy — run filter first','alert-circle'); return; }
  navigator.clipboard.writeText(fCleanedList.map(e=>e+',').join('\n')).then(()=>fToast('Copied '+fCleanedList.length+' emails','clipboard-check'));
}

function fDownloadTxt() {
  if(!fCleanedList.length){ fToast('Nothing to download','alert-circle'); return; }
  fTriggerDl(fCleanedList.map(e=>e+',').join('\n'),'beelzeads_clean_emails.txt','text/plain');
  fToast('Downloaded .txt','download');
}

function fDownloadCsv() {
  if(!fCleanedList.length){ fToast('Nothing to download','alert-circle'); return; }
  fTriggerDl('email\n'+fCleanedList.join('\n'),'beelzeads_clean_emails.csv','text/csv');
  fToast('Downloaded .csv','download');
}

function fTriggerDl(content,filename,type) {
  const blob=new Blob([content],{type}); const a=document.createElement('a');
  a.href=URL.createObjectURL(blob); a.download=filename; a.click(); URL.revokeObjectURL(a.href);
}

function fClearInput() {
  document.getElementById('fInputEmails').value='';
  document.getElementById('fInputCount').textContent='0';
  fToast('Input cleared','trash-2');
}

function fClearOutput() {
  fCleanedList=[];
  const out=document.getElementById('fOutput');
  out.style.color='#bbb'; out.style.fontStyle='italic';
  out.textContent='Filtered emails will appear here...';
  document.getElementById('fOutputCount').textContent='0';
  ['fStatTotal','fStatClean','fStatDupes','fStatInvalid'].forEach(id=>document.getElementById(id).textContent='0');
  fRenderDupes({},0);
  fToast('Output cleared','eraser');
}

function fSave() {
  const val=document.getElementById('fInputEmails').value;
  if(!val.trim()){ fToast('Nothing to save','alert-circle'); return; }
  localStorage.setItem('beelzeads_input',val);
  fToast('Saved to browser storage','save');
}

function fLoad() {
  const val=localStorage.getItem('beelzeads_input');
  if(val){ document.getElementById('fInputEmails').value=val; fUpdateCount(); fToast('Loaded from storage','folder-open'); }
  else { fToast('No saved data found','alert-circle'); }
}

function fToast(msg,icon='check-circle') {
  // Re-use the existing showToast if available in same scope
  // otherwise use simple alert fallback
  if(typeof showToast==='function') { showToast(msg,icon); }
}

