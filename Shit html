// ── FORMAT EMAIL TEXT (links + line breaks) ──
function formatEmailText(text) {
  if (!text) return '&nbsp;';
  var html = text;
  // Convert URLs to blue clickable links
  var urlRegex = /(https?:\/\/[^\s<>]+)/gi;
  html = html.replace(urlRegex, function(url) {
    var cleanUrl = url.replace(/[.,;:!?)]+$/, '');
    return '<a href="' + cleanUrl + '" style="color:#1a73e8;text-decoration:underline;" target="_blank">' + cleanUrl + '</a>';
  });
  // Convert newlines to <br> tags
  html = html.replace(/\n/g, '<br>');
  return html;
}

// ── CANVAS TO HTML ──
function canvasToPreviewHTML() {
  const headerText = document.getElementById('canvasHeaderText').innerText;
  const headerColor = document.getElementById('canvasHeader').style.background || emailColors.header;
  const headerTextColor = document.getElementById('canvasHeaderText').style.color || emailColors.headerText;
  const font = (typeof emailFont !== 'undefined') ? emailFont : 'Arial,Helvetica,sans-serif';
  
  let bodyItems = canvasElements
    .filter(e => e.type !== 'header')
    .sort((a,b) => a.y - b.y)
    .map(e => {
      if (e.type === 'text') {
        var elemFont = e.font || font;
        var alignStyle = e.textAlign ? 'text-align:' + e.textAlign + ';' : '';
        return '<p style="margin:16px 0;color:#222;font-size:15px;line-height:2;font-family:' + elemFont + ';' + alignStyle + '">' + formatEmailText(e.text) + '</p>';
            }else if (e.type === 'image') {
        if (e.linkUrl) {
          return `<div style="text-align:center;margin:14px 0;"><a href="${e.linkUrl}" target="_blank"><img src="${e.url}" style="max-width:100%;border-radius:8px;display:block;margin:0 auto;"/></a></div>`;
        }
        return `<div style="text-align:center;margin:14px 0;"><img src="${e.url}" style="max-width:100%;border-radius:8px;display:block;margin:0 auto;"/></div>`;
      }else if (e.type === 'button') {
        return '<div style="text-align:center;padding:8px 0;"><a href="' + e.url + '" style="background:' + e.color + ';color:#ffffff;padding:14px 38px;text-decoration:none;font-weight:700;border-radius:24px;display:inline-block;font-size:16px;font-family:' + font + ';">' + e.text + '</a></div>';
      }
      return '';
    }).join('');
  
  return { headerText, headerColor, headerTextColor, font, bodyItems };
}

function updateCanvasLayout() {
  var spacer = document.getElementById('canvasSpacer');
  if (!spacer) return;

  var maxBottom = 0;

  canvasElements.forEach(function(item) {
    if (!item || item.type === 'header') return;
    var el = document.querySelector('[data-id="' + item.id + '"]');
    if (!el) return;
    var top = parseFloat(el.style.top) || item.y || 0;
    // Use scrollHeight to capture actual rendered height including images
    var height = el.scrollHeight || el.offsetHeight || item.h || 40;
    maxBottom = Math.max(maxBottom, top + height);
  });

  var header = document.getElementById('canvasHeader');
  var headerHeight = header ? header.offsetHeight : 0;
  // Give a generous 60px gap below all content before footer
  var spacerHeight = Math.max(120, maxBottom - headerHeight + 60);
  spacer.style.height = spacerHeight + 'px';
}

