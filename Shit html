    canvasSavePreviewData();
  }
  syncCanvasHeader();
    // Auto-show footer on canvas when user picks a type
  var footer = document.getElementById('canvasFooter');
  if (footer && footer.style.display === 'none') {
    footer.style.display = 'block';
