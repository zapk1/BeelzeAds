function mgLoadSaved() {
  ['mgKey','mgDomain','mgYourEmail','mgFromName','mgFromEmail','mgSubject','mgBody','mgRecip','mgCtaUrl','mgCtaText','footerMoyaLink','footerMoyaPhone','mgBatchMin','mgBatchMax','mgDelayMin','mgDelayMax'].forEach(id => {
    const el = document.getElementById(id);
    const v = localStorage.getItem('beelze_' + id);
    if (el && v) el.value = v;
  });
  const domainEl = document.getElementById('mgDomain');
