    logoImg.src = logoState.url;
    logoImg.style.width = logoState.size + 'px';
    logoImg.style.height = 'auto';
    logoImg.style.maxWidth = '100%';
    logoImg.style.display = 'block';
    logoImg.style.borderRadius = '8px';

    if (logoState.position === 'above-title') {
      logoImg.style.margin = '0 auto 10px auto';
      header.insertBefore(logoImg, headerText);
      headerText.style.display = 'block';
    } else if (logoState.position === 'below-title') {
      logoImg.style.margin = '10px auto 0 auto';
      headerText.parentNode.insertBefore(logoImg, headerText.nextSibling);
      headerText.style.display = 'block';
    } else if (logoState.position === 'top-center') {
      // Move logo OUTSIDE header, before it
      var canvas = document.getElementById('emailCanvas');
      var existingTopLogo = document.getElementById('topCenterLogo');
      if (existingTopLogo) existingTopLogo.remove();
      var topLogoWrap = document.createElement('div');
