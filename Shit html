// ── Sync the Campaign Editor body text + CTA button into the canvas ──
function syncCanvasBodyFromEditor() {
  var bodyEl = document.getElementById('mgBody');
  var ctaUrlEl = document.getElementById('mgCtaUrl');
  var ctaTextEl = document.getElementById('mgCtaText');

  var bodyText = bodyEl ? bodyEl.value.trim() : '';
  var ctaUrl = ctaUrlEl ? ctaUrlEl.value.trim() : '';
  var ctaText = ctaTextEl ? ctaTextEl.value.trim() : 'Shop Now';
  var font = (typeof emailFont !== 'undefined') ? emailFont : 'Arial,Helvetica,sans-serif';

  var canvas = document.getElementById('emailCanvas');
  var header = document.getElementById('canvasHeader');
  var headerHeight = header ? header.offsetHeight : 80;

  // Remove any existing "editor-synced" elements
  document.querySelectorAll('.editor-synced-block').forEach(function(el){ el.remove(); });
  // Also remove by fixed ID (safety net for elements that lost their flag)
  var oldBody = document.querySelector('[data-id="ce_body_synced"]');
  if (oldBody) oldBody.remove();
  var oldCta = document.querySelector('[data-id="ce_cta_synced"]');
  if (oldCta) oldCta.remove();

  // Remove from canvasElements array too
  canvasElements = canvasElements.filter(function(ce){
    return !ce.editorSynced && ce.id !== 'ce_body_synced' && ce.id !== 'ce_cta_synced';
  });

  if (!bodyText && !ctaUrl) return;

  // Place body text block
  if (bodyText) {
    var id = 'ce_body_synced';
    var el = document.createElement('div');
    el.className = 'canvas-text-block editor-synced-block';
    el.setAttribute('data-id', id);
    el.contentEditable = 'false';
    el.style.left = '20px';
    el.style.top = (headerHeight + 20) + 'px';
    el.style.width = 'calc(100% - 40px)';
    el.style.fontFamily = font;
    el.style.color = '#444';
    el.style.fontSize = '15px';
    el.style.lineHeight = '1.7';
    el.style.whiteSpace = 'pre-wrap';
    el.textContent = bodyText;
    el.addEventListener('mousedown', canvasElementMouseDown);
    el.addEventListener('click', function(e) { if (isDragging) return; e.stopPropagation(); openTextEditPopup(id); });
    canvas.appendChild(el);

    canvasElements.push({
      id: id,
      type: 'text',
      el: el,
      x: 20,
      y: headerHeight + 20,
      text: bodyText,
      font: font,
      color: '#444',
      editorSynced: true
    });
  }

  // Place CTA button block
  if (ctaUrl || ctaText) {
    var bodyElHeight = bodyText ? (bodyText.split('\n').length * 26 + 60) : 0;
    var btnY = headerHeight + 20 + bodyElHeight + 20;
    var btnId = 'ce_cta_synced';
    var btnEl = document.createElement('a');
    btnEl.className = 'canvas-btn-block editor-synced-block';
    btnEl.setAttribute('data-id', btnId);
    btnEl.style.left = '50%';
    btnEl.style.transform = 'translateX(-50%)';
    btnEl.style.top = btnY + 'px';
    btnEl.style.background = (typeof emailColors !== 'undefined') ? emailColors.button : '#6366f1';
    btnEl.style.color = '#ffffff';
    btnEl.style.fontFamily = font;
    btnEl.textContent = ctaText || 'Shop Now';
    btnEl.href = ctaUrl || '#';
    btnEl.target = '_blank';
    btnEl.addEventListener('mousedown', function(e) { e.stopPropagation(); canvasElementMouseDown(e); });
    btnEl.addEventListener('click', function(e) { if (isDragging) { e.preventDefault(); return; } e.preventDefault(); e.stopPropagation(); editCanvasBtn(btnId); });
    canvas.appendChild(btnEl);

    canvasElements.push({
      id: btnId,
      type: 'button',
      el: btnEl,
      x: 140,
      y: btnY,
      text: ctaText || 'Shop Now',
      url: ctaUrl || '#',
      color: (typeof emailColors !== 'undefined') ? emailColors.button : '#6366f1', 
      editorSynced: true
    });
  }
}


function syncCanvasHeader() {
  var header = document.getElementById('canvasHeader');
  var headerText = document.getElementById('canvasHeaderText');
  if (!header || !headerText) return;
  var hdrColor = (typeof emailColors !== 'undefined') ? emailColors.header : '#ffffff';
