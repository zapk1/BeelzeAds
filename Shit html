// ── CLICK ON CANVAS: PLACE TEXT ──
function canvasClick(e) {
  if (isDragging || isResizing) return;
  if (e.target.closest('.canvas-text-block') || e.target.closest('.canvas-image-block') || e.target.closest('.canvas-btn-block') || e.target.closest('#canvasHeader') || e.target.closest('#canvasFooter')) return;
  
  const canvas = document.getElementById('emailCanvas');
  const rect = canvas.getBoundingClientRect();
  const x = e.clientX - rect.left;
  const y = e.clientY - rect.top;
  
  // Don't place text on header area
  const header = document.getElementById('canvasHeader');
  if (header) {
    const hRect = header.getBoundingClientRect();
    const hTop = hRect.top - rect.top;
    const hBot = hTop + hRect.height;
    if (y < hBot + 5) return;
  }
  
  // Don't place on footer
  const footer = document.getElementById('canvasFooter');
  if (footer) {
    const fRect = footer.getBoundingClientRect();
    const fTop = fRect.top - rect.top;
    if (y > fTop - 10) return;
  }
  
  canvasSaveState();
  const id = 'ce_' + (++canvasIdCounter);
  const defaultFont = (typeof emailFont !== 'undefined') ? emailFont : 'Arial,Helvetica,sans-serif';
  
  const el = document.createElement('div');
  el.className = 'canvas-text-block editing';
  el.contentEditable = 'true';
  el.setAttribute('data-id', id);
  el.style.left = x + 'px';
  el.style.top = y + 'px';
  el.style.fontFamily = defaultFont;
  el.style.color = '#444';
  el.style.fontSize = '15px';
  el.style.lineHeight = '1.7';
  el.style.minWidth = '40px';
  el.style.minHeight = '20px';
  el.style.cursor = 'text';  
  el.textContent = '';
  
  el.addEventListener('mousedown', canvasElementMouseDown);
  // Single click = focus for inline editing, Double click = open popup
  el.addEventListener('click', function(e) {
    if (isDragging) return;
    e.stopPropagation();
    // Single click: just focus inline
    if (el.contentEditable !== 'true') {
      el.contentEditable = 'true';
      el.classList.add('editing');
      el.style.cursor = 'text';
      el.focus();
    }
  });
  el.addEventListener('dblclick', function(e) {
    e.stopPropagation();
    // Save current inline text first
    var elem = canvasElements.find(function(ce){ return ce.id === id; });
    if (elem) { elem.text = el.textContent || ''; }
    el.contentEditable = 'false';
    el.classList.remove('editing');
    el.style.cursor = 'move';
    openTextEditPopup(id);
  });
  el.addEventListener('blur', function() {
    var txt = el.textContent.trim();
    if (!txt) {
      // Remove empty text blocks
      canvasElements = canvasElements.filter(function(ce){ return ce.id !== id; });
      el.remove();
      canvasSavePreviewData();
      return;
    }
    var elem = canvasElements.find(function(ce){ return ce.id === id; });
    if (elem) { elem.text = txt; }
    el.contentEditable = 'false';
    el.classList.remove('editing');
    el.style.cursor = 'move';
    canvasSavePreviewData();
  });
  
  canvas.appendChild(el);
  
  canvasElements.push({ id, type: 'text', el, x, y, text: '', font: defaultFont, color: '#444' });
  deselectAll();
  selectElement(el, id);
  canvasSavePreviewData();
  
  // Focus the element immediately so cursor appears
  el.focus();
}





// ── DRAG & SELECT ──
function canvasElementMouseDown(e) {
  if (e.target.contentEditable === 'true' && e.target.classList.contains('editing')) return;
  if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
  e.stopPropagation();
  
  const el = e.currentTarget;
  const id = el.getAttribute('data-id');
  
  if (e.target.classList.contains('canvas-resize-handle')) {
    isResizing = true;
    resizeTarget = el;
    const elem = canvasElements.find(ce => ce.id === id);
    resizeStartW = el.offsetWidth;
    resizeStartH = el.offsetHeight;
    dragStartX = e.clientX;
    dragStartY = e.clientY;
    return;
  }
  
  isDragging = true;
  dragTarget = el;
  dragStartX = e.clientX;
  dragStartY = e.clientY;
  dragOrigX = parseFloat(el.style.left) || 0;
  dragOrigY = parseFloat(el.style.top) || 0;
  deselectAll();
  selectElement(el, id);
}

function selectElement(el, id) {
  deselectAll();
  el.classList.add('canvas-selected');
  canvasSelectedId = id;
  
  // Show side controller
  document.getElementById('elemController').style.display = 'flex';
  
  // Add resize handles to images
  if (el.classList.contains('canvas-image-block')) {
    var handles = ['se','sw','ne','nw'];
    handles.forEach(function(pos){
      var h = document.createElement('div');
      h.className = 'canvas-resize-handle ' + pos;
      h.addEventListener('mousedown', canvasElementMouseDown);
      el.appendChild(h);
    });
  }
  
  // Restore text align
  var elem = canvasElements.find(function(e){ return e.id === id; });
  if (elem && elem.textAlign) {
    el.style.textAlign = elem.textAlign;
  }
}

function deselectAll() {
  document.querySelectorAll('.canvas-selected').forEach(function(el){ el.classList.remove('canvas-selected'); });
  document.querySelectorAll('.canvas-resize-handle').forEach(function(h){ h.remove(); });
  canvasSelectedId = null;
  var ctrl = document.getElementById('elemController');
  if (ctrl) ctrl.style.display = 'none';
  var footer = document.getElementById('canvasFooter');
  if (footer) footer.classList.remove('canvas-selected');
}

