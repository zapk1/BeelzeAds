  header.style.background = hdrColor;
  headerText.style.color = hdrTextColor;
  headerText.style.fontFamily = font;
  headerText.innerText = subject;

  // Remove old logo element if exists
  var oldLogo = header.querySelector('.canvas-header-logo');
  if (oldLogo) oldLogo.remove();

  // Render logo on canvas if set
  if (typeof logoState !== 'undefined' && logoState.url) {
    var logoImg = document.createElement('img');
