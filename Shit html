document.addEventListener('mousemove', function(e) {
  if (isDragging && dragTarget) {
    const dx = e.clientX - dragStartX;
    const dy = e.clientY - dragStartY;
    dragTarget.style.left = (dragOrigX + dx) + 'px';
    dragTarget.style.top = (dragOrigY + dy) + 'px';
  }
  if (isResizing && resizeTarget) {
    const dx = e.clientX - dragStartX;
    const dy = e.clientY - dragStartY;
    const newW = Math.max(30, resizeStartW + dx);
    const newH = Math.max(30, resizeStartH + dy);
    resizeTarget.style.width = newW + 'px';
    resizeTarget.style.height = newH + 'px';
    if (resizeTarget.classList.contains('canvas-image-block')) {
      resizeTarget.querySelector('img').style.width = '100%';
      resizeTarget.querySelector('img').style.height = '100%';
    }
  }
});

document.addEventListener('mouseup', function() {
  if (isDragging && dragTarget) {
    const id = dragTarget.getAttribute('data-id');
    updateCanvasElement(id, {
      x: parseFloat(dragTarget.style.left) || 0,
      y: parseFloat(dragTarget.style.top) || 0
    });
    canvasSaveState();
    canvasSavePreviewData();
  }
  if (isResizing && resizeTarget) {
    const id = resizeTarget.getAttribute('data-id');
    updateCanvasElement(id, {
      w: resizeTarget.offsetWidth,
      h: resizeTarget.offsetHeight
    });
    canvasSaveState();
    canvasSavePreviewData();
  }
  isDragging = false;
  dragTarget = null;
  isResizing = false;
  resizeTarget = null;
});

// ── TOUCH SUPPORT ──
document.addEventListener('touchmove', function(e) {
  if (isDragging && dragTarget) {
    const touch = e.touches[0];
    const dx = touch.clientX - dragStartX;
    const dy = touch.clientY - dragStartY;
    dragTarget.style.left = (dragOrigX + dx) + 'px';
    dragTarget.style.top = (dragOrigY + dy) + 'px';
    e.preventDefault();
  }
  if (isResizing && resizeTarget) {
    const touch = e.touches[0];
    const dx = touch.clientX - dragStartX;
    const dy = touch.clientY - dragStartY;
    resizeTarget.style.width = Math.max(30, resizeStartW + dx) + 'px';
    resizeTarget.style.height = Math.max(30, resizeStartH + dy) + 'px';
    e.preventDefault();
  }
}, { passive: false });

document.addEventListener('touchend', function() {
  if (isDragging && dragTarget) {
    const id = dragTarget.getAttribute('data-id');
    updateCanvasElement(id, {
      x: parseFloat(dragTarget.style.left) || 0,
      y: parseFloat(dragTarget.style.top) || 0
    });
    canvasSaveState();
    canvasSavePreviewData();
  }
  if (isResizing && resizeTarget) {
    const id = resizeTarget.getAttribute('data-id');
    updateCanvasElement(id, { w: resizeTarget.offsetWidth, h: resizeTarget.offsetHeight });
    canvasSaveState();
    canvasSavePreviewData();
  }
  isDragging = false; dragTarget = null; isResizing = false; resizeTarget = null;
});

function updateCanvasElement(id, updates) {
  const idx = canvasElements.findIndex(e => e.id === id);
  if (idx >= 0) Object.assign(canvasElements[idx], updates);
}

function canvasRebuildAll() {
  const canvas = document.getElementById('emailCanvas');
  // Remove all non-header elements
  document.querySelectorAll('#emailCanvas .canvas-text-block, #emailCanvas .canvas-image-block, #emailCanvas .canvas-btn-block').forEach(el => el.remove());
  
  canvasElements.forEach(ce => {
    if (ce.type === 'text') {
      const el = document.createElement('div');
      el.className = 'canvas-text-block';
      el.setAttribute('data-id', ce.id);
      el.contentEditable = 'false';
      el.style.left = ce.x + 'px';
      el.style.top = ce.y + 'px';
      el.style.fontFamily = ce.font || 'Arial,Helvetica,sans-serif';
      el.style.color = ce.color || '#444';
      el.style.fontSize = '15px';
      el.style.lineHeight = '1.7';
      el.style.minWidth = '20px';
      el.style.minHeight = '20px';
      if (ce.textAlign) el.style.textAlign = ce.textAlign;
      el.textContent = ce.text || '';
      el.addEventListener('mousedown', canvasElementMouseDown);
      el.addEventListener('click', function(e) {
        if (isDragging) return;
        e.stopPropagation();
        el.contentEditable = 'true';
        el.classList.add('editing');
        el.style.cursor = 'text';
        el.focus();
      });
      el.addEventListener('dblclick', function(e) {
        e.stopPropagation();
        var elem = canvasElements.find(function(c){ return c.id === ce.id; });
        if (elem) { elem.text = el.textContent || ''; }
        el.contentEditable = 'false';
        el.classList.remove('editing');
        el.style.cursor = 'move';
        openTextEditPopup(ce.id);
      });
      el.addEventListener('blur', function() {
        var elem = canvasElements.find(function(c){ return c.id === ce.id; });
        if (elem) { elem.text = el.textContent || elem.text; }
        el.contentEditable = 'false';
        el.classList.remove('editing');
        el.style.cursor = 'move';
        canvasSavePreviewData();
      });
      canvas.appendChild(el);
      ce.el = el;
       } else if (ce.type === 'image') {
      const el = document.createElement('div');
      el.className = 'canvas-image-block';
      el.setAttribute('data-id', ce.id);
      el.style.left = ce.x + 'px';
      el.style.top = ce.y + 'px';
      el.style.width = (ce.w || 250) + 'px';
      el.style.height = (ce.h || 'auto') !== 'auto' ? (ce.h || 180) + 'px' : 'auto';
      el.addEventListener('mousedown', canvasElementMouseDown);
      el.addEventListener('click', function(e) { if (isDragging) return; e.stopPropagation(); editCanvasImage(ce.id); });
      const img = document.createElement('img');
      img.src = ce.url;
      img.draggable = false;
      el.appendChild(img);
      canvas.appendChild(el);
      ce.el = el;
        } else if (ce.type === 'button') {
      const el = document.createElement('a');
      el.className = 'canvas-btn-block';
      el.setAttribute('data-id', ce.id);
      el.style.left = ce.x + 'px';
      el.style.top = ce.y + 'px';
      el.style.background = ce.color || '#ff5722';
      el.style.color = '#ffffff';
      el.style.fontFamily = (typeof emailFont !== 'undefined') ? emailFont : 'Arial,Helvetica,sans-serif';
      el.textContent = ce.text || 'Shop Now';
      el.href = ce.url || '#';
      el.target = '_blank';
      el.addEventListener('mousedown', function(e) { e.stopPropagation(); canvasElementMouseDown(e); });
      el.addEventListener('click', function(e) { if (isDragging) { e.preventDefault(); return; } e.preventDefault(); e.stopPropagation(); editCanvasBtn(ce.id); });
      canvas.appendChild(el);
      ce.el = el;
    }
  });
}

